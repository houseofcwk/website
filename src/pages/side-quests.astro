---
import Base from '../layouts/Base.astro';
import PortableText from '../components/PortableText.astro';
import { sanity } from '../lib/sanity';
import { SIDE_QUESTS_QUERY } from '../lib/queries';

let s: any = null;
try { s = await sanity.fetch(SIDE_QUESTS_QUERY); } catch { s = null; }

const heroEyebrow  = s?.heroEyebrow  ?? 'Side Quests';
const heroHeadline = s?.heroHeadline ?? 'Welcome to my Side Quests.';

const pageTitle = s?.seo?.title ?? 'Side Quests | CWK. Experience';
const pageDescription = s?.seo?.description ?? 'Short, self-initiated projects that showcase range, curiosity, and execution outside of core client work.';

interface QuestImage {
  src: string;
  alt: string;
  caption?: string;
}
interface QuestLink {
  label: string;
  href: string;
  icon: 'youtube' | 'instagram' | 'external';
}
interface QuestCredit {
  role: string;
  names: string;
}
interface Quest {
  slug: string;
  year: string;
  yearTone: 'cyan' | 'purple' | 'pink' | 'amber';
  status?: 'in-progress';
  title: string;
  description: string;
  images: QuestImage[];
  links?: QuestLink[];
  credits?: QuestCredit[];
}

const quests: Quest[] = [
  {
    slug: 'vending-machine',
    year: '2025',
    yearTone: 'cyan',
    status: 'in-progress',
    title: 'Experiential Content Vending Machine',
    description:
      "An experiential installation exploring content creation as a physical, real-world interaction. Walk up, drop a token, get a story.",
    images: [],
  },
  {
    slug: 'almost-real-things',
    year: '2021–2023',
    yearTone: 'amber',
    title: 'Almost Real Things Advisory Board',
    description:
      "Advisory board member contributing strategic creative direction to one of Austin's most inventive cultural publications.",
    images: [
      { src: '/images/side-quests/almost-real-things/01.webp', alt: 'Almost Real Things advisory board working session' },
      { src: '/images/side-quests/almost-real-things/02.webp', alt: 'Almost Real Things publication on display' },
    ],
    links: [
      { label: 'almostrealthings.com', href: 'https://almostrealthings.com/', icon: 'external' },
    ],
  },
  {
    slug: 'life-lessons-podcast',
    year: '2021–2022',
    yearTone: 'purple',
    title: 'Life Lessons of a Creative Entrepreneur Podcast',
    description:
      "A self-hosted podcast exploring entrepreneurship through the creative lens. Hosted with Raasin McIntosh; co-produced with Sam Needham.",
    images: [
      { src: '/images/side-quests/life-lessons-podcast/01.webp', alt: 'Life Lessons of a Creative Entrepreneur podcast cover' },
      { src: '/images/side-quests/life-lessons-podcast/02.webp', alt: 'Life Lessons podcast episode artwork' },
    ],
    credits: [
      { role: 'Hosts', names: 'Raasin McIntosh & Kris San' },
      { role: 'Produced by', names: 'Sam Needham & Kris San' },
    ],
  },
  {
    slug: 'keep-austin-voting',
    year: '2020',
    yearTone: 'pink',
    title: 'Keep Austin Voting',
    description:
      "A civic engagement campaign blending creative production with community outreach and voter activation in Austin, TX.",
    images: [
      { src: '/images/side-quests/keep-austin-voting/01.webp', alt: 'Keep Austin Voting field crew on location' },
      { src: '/images/side-quests/keep-austin-voting/02.webp', alt: 'Keep Austin Voting community outreach moment' },
      { src: '/images/side-quests/keep-austin-voting/03.webp', alt: 'Keep Austin Voting on-set production still' },
      { src: '/images/side-quests/keep-austin-voting/04.webp', alt: 'Keep Austin Voting volunteer team portrait' },
    ],
    links: [
      { label: 'YouTube',   href: 'https://www.youtube.com/@keepaustinvoting8835', icon: 'youtube' },
      { label: 'Instagram', href: 'https://www.instagram.com/keepaustinvoting_/', icon: 'instagram' },
    ],
    credits: [
      { role: 'Hosts', names: 'Raasin McIntosh & Kris San' },
      { role: 'Produced by', names: 'Sam Needham & Kris San' },
      { role: 'Creative Team', names: 'Giovanni Dueña, Casey Alfstad, Hanna Marie, Micalah Jones' },
    ],
  },
];
---

<Base title={pageTitle} description={pageDescription}>
  <!-- ── Hero ──────────────────────────────────────────────── -->
  <section class="sq-hero">
    <div class="sq-hero-inner">
      <span class="sq-eyebrow fade-up">
        <span class="sq-eyebrow-dot" aria-hidden="true"></span>
        {heroEyebrow}
      </span>
      <h1 class="sq-hero-title fade-up fade-up-delay-1">{heroHeadline}</h1>
      {!s?.body && (
        <p class="sq-hero-sub fade-up fade-up-delay-2">
          Short, self-initiated projects that showcase range, curiosity, and execution outside of core client work.
        </p>
      )}
      <div class="sq-hero-meta fade-up fade-up-delay-3">
        <span class="sq-hero-stat"><strong>{quests.length}</strong> quests</span>
        <span class="sq-hero-stat-sep" aria-hidden="true"></span>
        <span class="sq-hero-stat">2020 → 2025</span>
      </div>
    </div>
  </section>

  {s?.body ? (
    <section class="section body-section">
      <div class="section-inner">
        <div class="pt-body"><PortableText value={s.body} /></div>
      </div>
    </section>
  ) : (
  <>
    <!-- ── Quest sections ─────────────────────────────────────── -->
    {quests.map((q, i) => (
      <section class={`sq-quest sq-quest--${q.yearTone}`} id={q.slug}>
        <div class="sq-quest-inner">
          <header class="sq-quest-head reveal-up">
            <div class="sq-quest-meta">
              <span class={`sq-quest-num`} aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
              <span class="sq-quest-year">{q.year}</span>
              {q.status === 'in-progress' && (
                <span class="sq-quest-status">
                  <span class="sq-quest-status-dot"></span>
                  In progress
                </span>
              )}
            </div>
            <h2 class="sq-quest-title">{q.title}</h2>
            <p class="sq-quest-desc">{q.description}</p>

            {(q.links || q.credits) && (
              <div class="sq-quest-extras">
                {q.links && q.links.length > 0 && (
                  <div class="sq-quest-links">
                    {q.links.map((l) => (
                      <a href={l.href} target="_blank" rel="noopener noreferrer" class="sq-quest-link">
                        {l.icon === 'youtube' && (
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/></svg>
                        )}
                        {l.icon === 'instagram' && (
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                        )}
                        {l.icon === 'external' && (
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                        )}
                        <span>{l.label}</span>
                      </a>
                    ))}
                  </div>
                )}

                {q.credits && q.credits.length > 0 && (
                  <dl class="sq-quest-credits">
                    {q.credits.map((c) => (
                      <div class="sq-quest-credit">
                        <dt>{c.role}</dt>
                        <dd>{c.names}</dd>
                      </div>
                    ))}
                  </dl>
                )}
              </div>
            )}
          </header>

          {q.images.length > 0 ? (
            <div class={`sq-gallery sq-gallery--${q.images.length === 4 ? '4up' : '2up'} reveal-up reveal-delay-1`}>
              {q.images.map((img, idx) => (
                <figure class="sq-gallery-item" data-idx={idx}>
                  <button type="button" class="sq-gallery-trigger" aria-label={`Enlarge image: ${img.alt}`}>
                    <img
                      src={img.src}
                      alt={img.alt}
                      loading="lazy"
                      decoding="async"
                      width="1600"
                      height="1067"
                    />
                  </button>
                  {img.caption && <figcaption>{img.caption}</figcaption>}
                </figure>
              ))}
            </div>
          ) : (
            <div class="sq-gallery-empty reveal-up reveal-delay-1">
              <span class="sq-gallery-empty-icon" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <rect width="18" height="18" x="3" y="3" rx="2" ry="2"/>
                  <circle cx="9" cy="9" r="2"/>
                  <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
                </svg>
              </span>
              <p>Photos coming soon. Quest is still in motion.</p>
            </div>
          )}
        </div>
      </section>
    ))}

    <!-- ── Honorable Mentions ────────────────────────────────── -->
    <section class="section sq-mentions">
      <div class="section-inner">
        <div class="sq-mentions-divider"></div>
        <div class="sq-mentions-body">
          <span class="sq-mentions-eyebrow">Honorable Mentions</span>
          <p>
            Beyond these features, a range of smaller experiments, collabs, and creative detours have contributed to the larger body of work. Each one is a lesson, a connection, or a proof of concept.
          </p>
        </div>
      </div>
    </section>
  </>
  )}

  <!-- ── CTA ───────────────────────────────────────────────── -->
  <section class="section sq-cta-section">
    <div class="section-inner sq-cta-inner">
      <a href="/case-studies" class="btn btn-ghost">See All Case Studies →</a>
      <a href="/about" class="sq-cta-secondary">← Back to About Kris</a>
    </div>
  </section>

  <!-- ── Lightbox ─────────────────────────────────────────── -->
  <dialog id="sq-lightbox" class="sq-lightbox" aria-label="Image viewer">
    <button type="button" class="sq-lightbox-close" aria-label="Close image">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
      </svg>
    </button>
    <button type="button" class="sq-lightbox-prev" aria-label="Previous image">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="m15 18-6-6 6-6"/>
      </svg>
    </button>
    <button type="button" class="sq-lightbox-next" aria-label="Next image">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="m9 18 6-6-6-6"/>
      </svg>
    </button>
    <figure class="sq-lightbox-figure">
      <img alt="" />
      <figcaption hidden></figcaption>
    </figure>
  </dialog>
</Base>

<script>
  // Lightbox: prev/next within the *current quest's* gallery so navigation
  // doesn't unexpectedly jump between projects.
  const dialog = document.getElementById('sq-lightbox') as HTMLDialogElement | null;
  if (dialog) {
    const dialogImg = dialog.querySelector('img') as HTMLImageElement;
    const dialogCap = dialog.querySelector('figcaption') as HTMLElement;
    const closeBtn  = dialog.querySelector('.sq-lightbox-close') as HTMLButtonElement;
    const prevBtn   = dialog.querySelector('.sq-lightbox-prev')  as HTMLButtonElement;
    const nextBtn   = dialog.querySelector('.sq-lightbox-next')  as HTMLButtonElement;

    let currentGallery: HTMLImageElement[] = [];
    let currentIdx = 0;

    const renderImg = (img: HTMLImageElement) => {
      dialogImg.src = img.currentSrc || img.src;
      dialogImg.alt = img.alt || '';
      const cap = (img.closest('figure')?.querySelector('figcaption') as HTMLElement | null);
      if (cap && cap.textContent && cap.textContent.trim().length > 0) {
        dialogCap.textContent = cap.textContent.trim();
        dialogCap.hidden = false;
      } else {
        dialogCap.textContent = '';
        dialogCap.hidden = true;
      }
    };

    const updateNavVisibility = () => {
      const showNav = currentGallery.length > 1;
      prevBtn.style.display = showNav ? 'flex' : 'none';
      nextBtn.style.display = showNav ? 'flex' : 'none';
    };

    const openFromTrigger = (trigger: HTMLButtonElement) => {
      const img = trigger.querySelector('img') as HTMLImageElement | null;
      if (!img) return;
      const gallery = trigger.closest('.sq-gallery') as HTMLElement | null;
      currentGallery = gallery
        ? Array.from(gallery.querySelectorAll<HTMLImageElement>('.sq-gallery-trigger img'))
        : [img];
      currentIdx = currentGallery.indexOf(img);
      renderImg(img);
      updateNavVisibility();
      dialog.showModal();
    };

    const step = (delta: number) => {
      if (currentGallery.length < 2) return;
      currentIdx = (currentIdx + delta + currentGallery.length) % currentGallery.length;
      renderImg(currentGallery[currentIdx]);
    };

    document.querySelectorAll<HTMLButtonElement>('.sq-gallery-trigger').forEach((btn) => {
      btn.addEventListener('click', () => openFromTrigger(btn));
    });

    closeBtn.addEventListener('click', () => dialog.close());
    prevBtn.addEventListener('click', () => step(-1));
    nextBtn.addEventListener('click', () => step(1));

    // Click outside the figure closes
    dialog.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target === dialog) dialog.close();
    });

    // Arrow keys when open
    document.addEventListener('keydown', (e) => {
      if (!dialog.open) return;
      if (e.key === 'ArrowLeft')  step(-1);
      if (e.key === 'ArrowRight') step(1);
    });
  }
</script>

<style>
  /* ── Hero ─────────────────────────────────────────────── */
  .sq-hero {
    position: relative;
    padding: 144px 24px 72px;
    text-align: center;
    overflow: hidden;
  }
  .sq-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(700px 320px at 12% 5%, rgba(0,229,255,0.06) 0%, transparent 65%),
      radial-gradient(600px 320px at 90% 95%, rgba(251,48,121,0.06) 0%, transparent 65%);
    pointer-events: none;
  }
  .sq-hero-inner {
    position: relative;
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
  }

  .sq-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    background: rgba(0, 229, 255, 0.08);
    border: 1px solid rgba(0, 229, 255, 0.22);
    border-radius: 100px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cyan);
  }
  .sq-eyebrow-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--cyan);
    box-shadow: 0 0 8px rgba(0, 229, 255, 0.55);
  }
  .sq-hero-title {
    margin: 0;
    font-size: clamp(36px, 5.6vw, 60px);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--text);
  }
  .sq-hero-sub {
    margin: 0;
    max-width: 540px;
    font-size: 16px;
    line-height: 1.65;
    color: var(--muted);
  }
  .sq-hero-meta {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    margin-top: 6px;
    padding: 7px 16px;
    background: var(--glass);
    border: 1px solid var(--gb);
    border-radius: 100px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--muted);
  }
  .sq-hero-meta strong { color: var(--text); font-weight: 800; }
  .sq-hero-stat-sep {
    width: 1px;
    height: 12px;
    background: rgba(255,255,255,0.16);
  }

  /* ── Quest section ────────────────────────────────────── */
  .sq-quest {
    position: relative;
    padding: 72px 24px;
  }
  .sq-quest:nth-child(odd) { background: rgba(255,255,255,0.012); }
  .sq-quest-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 360px) 1fr;
    gap: 56px;
    align-items: start;
  }

  .sq-quest-head {
    position: sticky;
    top: 96px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .sq-quest-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
  }
  .sq-quest-num {
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.18em;
    color: var(--dim);
    padding: 5px 9px;
    border-radius: 6px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
  }
  .sq-quest-year {
    display: inline-flex;
    padding: 5px 11px;
    border-radius: 6px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
  }
  .sq-quest--cyan   .sq-quest-year { color: #9be7f3; background: rgba(0,229,255,0.08);  border: 1px solid rgba(0,229,255,0.22); }
  .sq-quest--purple .sq-quest-year { color: #c9c2ff; background: rgba(123,97,255,0.08); border: 1px solid rgba(123,97,255,0.28); }
  .sq-quest--pink   .sq-quest-year { color: #f3a4c1; background: rgba(251,48,121,0.08); border: 1px solid rgba(251,48,121,0.28); }
  .sq-quest--amber  .sq-quest-year { color: #f0c389; background: rgba(224,168,120,0.08);border: 1px solid rgba(224,168,120,0.28); }

  .sq-quest-status {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 10px;
    border-radius: 100px;
    background: rgba(0,229,255,0.06);
    border: 1px solid rgba(0,229,255,0.22);
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--cyan);
  }
  .sq-quest-status-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--cyan);
    box-shadow: 0 0 8px rgba(0,229,255,0.65);
    animation: sq-pulse 2.4s ease-out infinite;
  }
  @keyframes sq-pulse {
    0%   { box-shadow: 0 0 0 0   rgba(0,229,255,0.55); }
    70%  { box-shadow: 0 0 0 8px rgba(0,229,255,0);    }
    100% { box-shadow: 0 0 0 0   rgba(0,229,255,0);    }
  }

  .sq-quest-title {
    margin: 0;
    font-size: clamp(22px, 2.4vw, 28px);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--text);
    line-height: 1.2;
  }
  .sq-quest-desc {
    margin: 0;
    font-size: 14.5px;
    line-height: 1.65;
    color: var(--muted);
  }

  .sq-quest-extras {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-top: 4px;
  }
  .sq-quest-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .sq-quest-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 12px;
    border-radius: 8px;
    background: rgba(0,229,255,0.06);
    border: 1px solid rgba(0,229,255,0.22);
    color: var(--cyan);
    font-size: 12px;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s ease, border-color 0.2s ease;
  }
  .sq-quest-link:hover {
    background: rgba(0,229,255,0.12);
    border-color: rgba(0,229,255,0.4);
  }

  .sq-quest-credits {
    margin: 0;
    padding: 14px 16px;
    background: rgba(255,255,255,0.02);
    border: 1px solid var(--gb);
    border-radius: 10px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .sq-quest-credit {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 10px;
    margin: 0;
    align-items: baseline;
  }
  .sq-quest-credit dt {
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--dim);
  }
  .sq-quest-credit dd {
    margin: 0;
    font-size: 13px;
    color: var(--muted);
    line-height: 1.5;
  }

  /* ── Gallery ──────────────────────────────────────────── */
  .sq-gallery {
    display: grid;
    gap: 12px;
  }
  .sq-gallery--2up { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .sq-gallery--4up {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    grid-auto-rows: 1fr;
  }

  .sq-gallery-item {
