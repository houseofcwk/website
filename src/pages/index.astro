<script>
  (() => {
    const INTERVAL = 2800; // ms between flips

    const track = document.getElementById('word-flip-track') as HTMLElement | null;
    if (!track) return;

    // Real items exclude the sentinel (last duplicate)
    const allItems = Array.from(track.querySelectorAll<HTMLElement>('.word-flip-item'));
    const real  = allItems.filter(el => !el.classList.contains('word-flip-sentinel'));
    const total = real.length; // 7 real words
    if (total < 2) return;

    // The sentinel is the 8th slot (index = total) — a visual clone of slot 0.
    // We animate 0 → 1 → 2 → … → total (sentinel), then snap back to 0 instantly.

    let current = 0;
    track.style.transform = 'translateY(0)';

    function advance() {
      const visualNext = current + 1; // may equal total (sentinel slot)

      track!.classList.add('is-animating');
      track!.style.transform = `translateY(-${visualNext * 1.2}em)`;

      // Update aria on real items
      real[current % total].setAttribute('aria-hidden', 'true');
      real[visualNext % total].setAttribute('aria-hidden', 'false');

      if (visualNext === total) {
        // We just slid to the sentinel. After the transition ends,
        // snap back to slot 0 (visually identical) without transition.
        track!.addEventListener('transitionend', () => {
          track!.classList.remove('is-animating');
          track!.classList.add('no-transition');
          track!.style.transform = 'translateY(0)';
          void (track!.offsetHeight); // force reflow to commit no-transition
          track!.classList.remove('no-transition');
          current = 0;
        }, { once: true });
      } else {
        current = visualNext;
      }
    }

    setTimeout(() => {
      setInterval(advance, INTERVAL);
    }, INTERVAL);
  })();

  /* ── Reveal-on-scroll for work mosaic + section headers ── */
  (() => {
    const targets = document.querySelectorAll<HTMLElement>('.reveal-card, .reveal-up');
    if (!targets.length) return;

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced || !('IntersectionObserver' in window)) {
      targets.forEach(el => el.classList.add('is-visible'));
      return;
    }

    const io = new IntersectionObserver((entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          io.unobserve(entry.target);
        }
      }
    }, { rootMargin: '0px 0px -10% 0px', threshold: 0.12 });

    targets.forEach(el => io.observe(el));
  })();
</script>

<script>
  // Lazy-load the abstract Lottie in the hero background.
  // Skips on reduced-motion; fetches lottie-web ESM only when the element
  // scrolls into view (first paint is unaffected).
  (() => {
    const host = document.querySelector<HTMLElement>('.hero-lottie');
    if (!host) return;
    if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const path = host.dataset.lottie;
    if (!path) return;

    const lottieUrl = 'https://cdn.jsdelivr.net/npm/lottie-web@5.12.2/+esm';
    const mount = () => import(/* @vite-ignore */ lottieUrl)
      .then(({ default: lottie }) => {
        const anim = lottie.loadAnimation({
          container: host,
          renderer: 'svg',
          loop: true,
          autoplay: true,
          path,
          // progressiveLoad:false buffers the whole JSON before first paint —
          // prevents the loop-boundary flash some browsers show when chunks
          // are still streaming in. preserveAspectRatio keeps it centered.
          rendererSettings: { progressiveLoad: false, preserveAspectRatio: 'xMidYMid slice' },
        });

        // Sub-frame interpolation smooths the transition at the loop seam
        // (otherwise lottie snaps to discrete integer frames and the jump
        // from last → first is visible). Slower speed makes the loop feel
        // ambient instead of hypnotic.
        anim.setSubframe(true);
        anim.setSpeed(0.5);

        // Fade in once the first frame has actually rendered to the DOM.
        anim.addEventListener('DOMLoaded', () => host.classList.add('is-ready'));
      })
      .catch(() => { /* silent — hero still renders without it */ });

    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries, obs) => {
        if (entries.some(e => e.isIntersecting)) { obs.disconnect(); mount(); }
      });
      io.observe(host);
    } else {
      mount();
    }
  })();
</script>
