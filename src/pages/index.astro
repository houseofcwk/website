---
import Base from '../layouts/Base.astro';
import PortableText from '../components/PortableText.astro';
import WaitlistForm from '../components/WaitlistForm';
import { sanity } from '../lib/sanity';
import { HOME_QUERY } from '../lib/queries';

// Sanity-first; fall through to the existing hardcoded copy when the
// homePage doc isn't published. The site builds either way.
let s: any = null;
try { s = await sanity.fetch(HOME_QUERY); } catch { s = null; }

const HARDCODED_PHRASES = [
  'sports agent', 'brand architect', 'growth operator', 'deal closer',
  'systems builder', 'leverage partner', 'revenue strategist',
];
const HARDCODED_PILLARS = [
  { key: 'mind',   title: 'Mind',   body: 'Strategic clarity, decision frameworks, mental performance, and clearing psychological blockers that slow momentum.' },
  { key: 'body',   title: 'Body',   body: 'Operational systems, time and energy optimization, process documentation, and building infrastructure that runs without you.' },
  { key: 'soul',   title: 'Soul',   body: 'Legacy building, IP development, thought leadership positioning, and turning your expertise into compounding authority.' },
  { key: 'pocket', title: 'Pocket', body: 'Revenue systems, opportunity sourcing, deal structuring, and building the financial engine that funds your vision.' },
];

const pageTitle       = s?.seo?.title       ?? 'CWK. Experience — The Sports Agent for Entrepreneurs';
const pageDescription = s?.seo?.description ?? "CWK. installs the infrastructure that scales high-performing entrepreneurs. Long-term business management, not consulting.";
const heroEyebrow     = s?.heroEyebrow      ?? 'Personal Leverage OS';
const heroHeadline    = s?.heroHeadline     ?? 'CWK. is like a';
const wordPhrases: string[] = (Array.isArray(s?.wordFlipPhrases) && s.wordFlipPhrases.length > 0)
  ? s.wordFlipPhrases : HARDCODED_PHRASES;
const heroCtaLabel    = s?.heroCta?.label   ?? 'Join Waitlist';
const heroCtaHref     = s?.heroCta?.href    ?? '#';
const pillars = (Array.isArray(s?.pillars) && s.pillars.length > 0) ? s.pillars : HARDCODED_PILLARS;
---

<Base
  title={pageTitle}
  description={pageDescription}
>
  <!-- ── Hero ─────────────────────────────────────────────── -->
  <section class="hero">

    <!-- Animated background layer -->
    <div class="hero-bg" aria-hidden="true">

      <!-- Ambient glow orbs -->
      <div class="orb orb-cyan"></div>
      <div class="orb orb-purple"></div>
      <div class="orb orb-pink"></div>

      <!-- Light streaks -->
      <div class="streak streak-1"></div>
      <div class="streak streak-2"></div>
      <div class="streak streak-3"></div>

      <!-- Floating glass cards — left side -->
      <div class="float-card fc-1">
        <div class="fc-bar fc-bar--md" style="width:100px"></div>
        <div class="fc-bar fc-bar--sm" style="width:60px"></div>
        <div class="fc-bar fc-bar--md" style="width:120px"></div>
      </div>
      <div class="float-card fc-2">
        <div class="fc-bar fc-bar--sm" style="width:80px"></div>
        <div class="fc-bar fc-bar--md" style="width:110px"></div>
      </div>
      <div class="float-card fc-3">
        <div class="fc-bar fc-bar--md" style="width:90px"></div>
        <div class="fc-bar fc-bar--sm" style="width:50px"></div>
      </div>

      <!-- Floating glass cards — right side -->
      <div class="float-card fc-4">
        <div class="fc-bar fc-bar--md" style="width:120px"></div>
        <div class="fc-bar fc-bar--sm" style="width:70px"></div>
        <div class="fc-bar fc-bar--md" style="width:100px"></div>
      </div>
      <div class="float-card fc-5">
        <div class="fc-bar fc-bar--sm" style="width:90px"></div>
        <div class="fc-bar fc-bar--md" style="width:110px"></div>
      </div>
      <div class="float-card fc-6">
        <div class="fc-bar fc-bar--md" style="width:80px"></div>
        <div class="fc-bar fc-bar--sm" style="width:50px"></div>
      </div>

      <!-- Decorative lines -->
      <div class="deco-line dl-1"></div>
      <div class="deco-line dl-2"></div>
      <div class="deco-line dl-3"></div>
      <div class="deco-line dl-4"></div>

      <!-- Decorative icons (Lucide: trending-up, hexagon, zap, sparkles) -->
      <svg class="deco-icon di-1" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/>
        <polyline points="16 7 22 7 22 13"/>
      </svg>
      <svg class="deco-icon di-2" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
      </svg>
      <svg class="deco-icon di-3" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
      </svg>
      <svg class="deco-icon di-4" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/>
        <path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/>
      </svg>

      <!-- Accent squares -->
      <div class="acc-sq as-1"></div>
      <div class="acc-sq as-2"></div>
      <div class="acc-sq as-3"></div>

      <!-- Abstract Lottie (loaded lazily via lottie-web) -->
      <div class="hero-lottie" data-lottie="/animations/technology.json" aria-hidden="true"></div>
    </div>

    <!-- Hero content -->
    <div class="hero-inner">
      <span class="hero-eyebrow fade-up">{heroEyebrow}</span>
      <h1 class="hero-headline fade-up fade-up-delay-1">
        <span class="hl-line hl-white">{heroHeadline}</span>
        <span class="hl-line hl-cyan word-flip-wrap" aria-live="polite" aria-atomic="true">
          <span class="word-flip-track" id="word-flip-track">
            {wordPhrases.map((phrase, i) => (
              <span class="word-flip-item" aria-hidden={i !== 0}>{phrase}</span>
            ))}
            <!-- duplicate of first item — enables seamless infinite loop -->
            <span class="word-flip-item word-flip-sentinel" aria-hidden="true">{wordPhrases[0]}</span>
          </span>
        </span>
        <span class="hl-line hl-white">for entrepreneurs.</span>
      </h1>
      {s?.heroSubtext ? (
        <div class="hero-sub fade-up fade-up-delay-2 pt-hero-sub"><PortableText value={s.heroSubtext} /></div>
      ) : (
        <p class="hero-sub fade-up fade-up-delay-2">
          We rep your career, install the infrastructure that scales you, and
          manage your growth like a PE firm manages a portfolio company.
        </p>
      )}
      <div class="hero-ctas fade-up fade-up-delay-3">
        <button class="btn-hero-join" data-open-waitlist>
          {heroCtaLabel}
          <svg class="btn-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </button>
        <div class="hero-links">
          <a href="/brand-mirror" class="hero-link">
            <span class="hl-emoji">🔥</span>
            <span class="hl-text">Find Your Bottleneck</span>
            <em class="hl-badge">Free Tool</em>
          </a>
          <span class="hero-link-divider" aria-hidden="true"></span>
          <a href="/product" class="hero-link">
            <span class="hl-emoji">👁️</span>
            <span class="hl-text">See the Product</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Mission ───────────────────────────────────────────── -->
  <section class="section mission">
    <div class="section-inner">
      <div class="mission-card glass-card">
        <span class="eyebrow">The Problem</span>
        <h2>Your expertise is compounding.<br>Your infrastructure isn't.</h2>
        <div class="mission-body">
          <p>
            Most high-performing entrepreneurs between $150k–$5M are stuck because their infrastructure is leaking. Systems are fragmented. Authority is scattered across tools or locked in your head. Deals die because you can't prove value fast enough, or you forgot to follow up.
          </p>
          <p>
            The result? You're working harder to earn the same.
          </p>
          <p>
            CWK. is your long-term partner. We install the infrastructure that catches everything, then manage your operations and coordinate your growth. We're not consultants who give advice and leave. We're business managers who acquire a stake in your future and stay for the long game.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Four Pillars ──────────────────────────────────────── -->
  <section class="section pillars">
    <div class="section-inner">
      <div class="pillars-header">
        <span class="pill-eyebrow reveal-up">
          <span class="pill-dot" aria-hidden="true"></span>
          How We Support You
        </span>
        <h2 class="pillars-title reveal-up reveal-delay-1">We support you across four categories.</h2>
        <p class="pillars-sub reveal-up reveal-delay-2">The PLOS framework — Mind, Body, Soul, Pocket — covers the full operating surface of a high-leverage business.</p>
      </div>

      <div class="pillars-grid">
        {pillars.map((p: any, i: number) => (
          <article class={`pillar-card pillar-card--${p.key} glass-card reveal-card`} style={`--reveal-i:${i}`}>
            <div class="pillar-icon" aria-hidden="true">
              {p.key === 'mind' && (
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/>
                  <path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/>
                  <path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"/>
                  <path d="M17.599 6.5a3 3 0 0 0 .399-1.375"/>
                  <path d="M6.003 5.125A3 3 0 0 0 6.401 6.5"/>
                  <path d="M3.477 10.896a4 4 0 0 1 .585-.396"/>
                  <path d="M19.938 10.5a4 4 0 0 1 .585.396"/>
                  <path d="M6 18a4 4 0 0 1-1.967-.516"/>
                  <path d="M19.967 17.484A4 4 0 0 1 18 18"/>
                </svg>
              )}
              {p.key === 'body' && (
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 12h-2.48a2 2 0 0 0-1.93 1.46l-2.35 8.36a.5.5 0 0 1-.96 0L9.24 2.18a.5.5 0 0 0-.96 0l-2.35 8.36A2 2 0 0 1 4 12H2"/>
                </svg>
              )}
              {p.key === 'soul' && (
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/>
                </svg>
              )}
              {p.key === 'pocket' && (
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M19 7V4a1 1 0 0 0-1-1H5a2 2 0 0 0 0 4h15a1 1 0 0 1 1 1v4h-3a2 2 0 0 0 0 4h3a1 1 0 0 0 1-1v-2a1 1 0 0 0-1-1"/>
                  <path d="M3 5v14a2 2 0 0 0 2 2h15a1 1 0 0 0 1-1v-4"/>
                </svg>
              )}
            </div>
            <div class="pillar-body">
              <h3>{p.title}</h3>
              <p>{p.body}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Social Proof — Metrics Grid ────────────────────────── -->
  <section class="section proof">
    <div class="section-inner">
      <div class="proof-grid">
        <div class="stat-card reveal-card" style="--reveal-i:0">
          <span class="stat-number">$1M <span class="stat-arrow" aria-hidden="true">→</span> $5M</span>
          <span class="stat-label">Revenue Growth</span>
        </div>
        <div class="stat-card reveal-card" style="--reveal-i:1">
          <span class="stat-number">10x</span>
          <span class="stat-label">Content Output</span>
        </div>
        <div class="stat-card reveal-card" style="--reveal-i:2">
          <span class="stat-number">20–30%</span>
          <span class="stat-label">Shorter Sales Cycles</span>
        </div>
        <div class="stat-card reveal-card" style="--reveal-i:3">
          <span class="stat-number">60%</span>
          <span class="stat-label">Less Decision Fatigue</span>
        </div>
        <div class="stat-card reveal-card" style="--reveal-i:4">
          <span class="stat-number">80%</span>
          <span class="stat-label">Less Messaging Confusion</span>
        </div>
        <div class="stat-card reveal-card" style="--reveal-i:5">
          <span class="stat-number">6-Figure</span>
          <span class="stat-label">Grants Secured</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Featured Work — Mosaic Gallery ────────────────────── -->
  <section class="section work-mosaic">
    <div class="section-inner">
      <div class="work-mosaic-header">
        <span class="pill-eyebrow reveal-up">
          <span class="pill-dot" aria-hidden="true"></span>
          The Work
        </span>
        <h2 class="work-mosaic-title reveal-up reveal-delay-1">Brands Built For The Real World.</h2>
        <p class="work-mosaic-sub reveal-up reveal-delay-2">A collection of work bridging education, community, tech, &amp; art.</p>
      </div>

      <div class="mosaic-grid">
        <a href="/work/the-lab-miami" class="mosaic-card mosaic-card--wide reveal-card" style="--reveal-i:0">
          <img src="/images/work/lab-miami.webp" alt="The LAB Miami innovation campus" width="1440" height="804" loading="lazy" decoding="async" />
          <div class="mosaic-overlay">
            <span class="mosaic-tag">Builder Hub</span>
            <h3 class="mosaic-title">The LAB Miami</h3>
            <p class="mosaic-meta">20–30% faster sales cycles</p>
            <span class="mosaic-arrow" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </div>
        </a>

        <a href="/work/rob-dial" class="mosaic-card reveal-card" style="--reveal-i:1">
          <img src="/images/work/rob-dial.webp" alt="Rob Dial podcast studio" width="1200" height="654" loading="lazy" decoding="async" />
          <div class="mosaic-overlay">
            <span class="mosaic-tag">Podcast</span>
            <h3 class="mosaic-title">Rob Dial</h3>
            <p class="mosaic-meta">Revenue $1M → $5M</p>
            <span class="mosaic-arrow" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </div>
        </a>

        <a href="/work/spraycation" class="mosaic-card reveal-card" style="--reveal-i:2">
          <img src="/images/work/spraycation.webp" alt="SPRAYCATION experiential art tour" width="1000" height="546" loading="lazy" decoding="async" />
          <div class="mosaic-overlay">
            <span class="mosaic-tag">Experiential</span>
            <h3 class="mosaic-title">SPRAYCATION</h3>
            <p class="mosaic-meta">6-city tour executed</p>
            <span class="mosaic-arrow" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </div>
        </a>

        <a href="/work/dawa" class="mosaic-card reveal-card" style="--reveal-i:3">
          <img src="/images/work/dawa.webp" alt="DAWA non-profit education program" width="1000" height="546" loading="lazy" decoding="async" />
          <div class="mosaic-overlay">
            <span class="mosaic-tag">Non-Profit</span>
            <h3 class="mosaic-title">DAWA</h3>
            <p class="mosaic-meta">A dignity project unveiled</p>
            <span class="mosaic-arrow" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </div>
        </a>

        <a href="/work/stephy-lee" class="mosaic-card reveal-card" style="--reveal-i:4">
          <img src="/images/work/stephy-lee.webp" alt="Stephy Lee music artist" width="1000" height="546" loading="lazy" decoding="async" />
          <div class="mosaic-overlay">
            <span class="mosaic-tag">Creative Founder</span>
            <h3 class="mosaic-title">Stephy Lee</h3>
            <p class="mosaic-meta">SXSW stage secured</p>
            <span class="mosaic-arrow" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </div>
        </a>
      </div>

      <div class="work-cta reveal-up reveal-delay-3">
        <a href="/work" class="btn btn-ghost">See All Work →</a>
      </div>
    </div>
  </section>

  <!-- ── Product Preview ───────────────────────────────────── -->
  <section class="section product-preview">
    <div class="section-inner">
      <div class="product-preview-card glass-card">
        <span class="eyebrow">The Platform</span>
        <h2>See what's inside CWK. Agent+</h2>
        <p>Your personal command center for managing relationships, tracking momentum, and executing with clarity. Built on the PLOS framework. Powered by AI.</p>
        <a href="/product" class="btn btn-gradient">Explore the Product →</a>

        <div class="product-feature-tags">
          <span class="tag">Player Dashboard</span>
          <span class="tag tag-purple">Relationships CRM</span>
          <span class="tag">Pipeline Kanban</span>
          <span class="tag tag-pink">kaia AI Chat</span>
          <span class="tag tag-purple">Brand Destination</span>
          <span class="tag">Daily Actions</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Waitlist ──────────────────────────────────────────── -->
  <section id="waitlist" class="section waitlist-section">
    <div class="section-inner">
      <div class="waitlist-card glass-card">
        <span class="eyebrow">Early Access</span>
        <h2>We're building something for founders<br>who are done patching leaks.</h2>
        <p class="section-sub">
          CWK. Agent+ is the operating system that manages your growth across Mind, Body, Soul, and Pocket. Join the waitlist to get early access when we launch.
        </p>
        <WaitlistForm client:visible />
        <p class="social-proof-line">Join 50+ founders already on the list.</p>
      </div>
    </div>
  </section>

  <!-- JSON-LD Organization structured data -->
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "CWK. Experience",
    "url": "https://houseofcwk.com",
    "description": "CWK. is the sports agent for entrepreneurs. We install the infrastructure that scales high-performing founders.",
    "logo": "https://houseofcwk.com/og-image.png"
  })} />
</Base>

<style>
  /* ── Hero ─────────────────────────────────────────── */
  .hero {
    position: relative;
    overflow: hidden;
    min-height: 800px;
    display: flex;
    align-items: center;
    padding-top: 144px;
    padding-bottom: 96px;
  }

  /* ── Background layer ─────────────────────────────── */
  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  /* Glow orbs */
  .orb {
    position: absolute;
    border-radius: 50%;
  }
  .orb-cyan {
    width: 600px; height: 500px;
    left: 3.5%; top: 120px;
    background: radial-gradient(circle, #00E5FF 0%, transparent 70%);
    opacity: 0.07;
    filter: blur(120px);
    animation: orb-breathe 8s ease-in-out infinite;
  }
  .orb-purple {
    width: 500px; height: 400px;
    right: 5%; top: 100px;
    background: radial-gradient(circle, #7B61FF 0%, transparent 70%);
    opacity: 0.06;
    filter: blur(110px);
    animation: orb-breathe 10s ease-in-out infinite 2s;
  }
  .orb-pink {
    width: 300px; height: 250px;
    left: 50%; top: 460px;
    background: radial-gradient(circle, #FB3079 0%, transparent 70%);
    opacity: 0.03;
    filter: blur(80px);
    animation: orb-breathe-cx 12s ease-in-out infinite 4s;
  }
  @keyframes orb-breathe {
    0%, 100% { scale: 1; }
    50%       { scale: 1.08; }
  }
  @keyframes orb-breathe-cx {
    0%, 100% { translate: -50% 0; scale: 1; }
    50%       { translate: -50% 0; scale: 1.1; }
  }

  /* Light streaks */
  .streak {
    position: absolute;
    border-radius: 2px;
  }
  .streak-1 {
    width: 70%; height: 2px;
    left: 7%; top: 200px;
    background: #00E5FF;
    opacity: 0.1; filter: blur(25px);
    rotate: 4deg;
    animation: streak-drift 15s ease-in-out infinite;
  }
  .streak-2 {
    width: 76%; height: 3px;
    left: 14%; top: 400px;
    background: #7B61FF;
    opacity: 0.1; filter: blur(28px);
    rotate: -3deg;
    animation: streak-drift 18s ease-in-out infinite 3s;
  }
  .streak-3 {
    width: 63%; height: 2px;
    left: 10%; top: 550px;
    background: #FB3079;
    opacity: 0.12; filter: blur(22px);
    rotate: 5deg;
    animation: streak-drift 12s ease-in-out infinite 6s;
  }
  @keyframes streak-drift {
    0%, 100% { translate: 0 0; opacity: 0.1; }
    50%       { translate: 0 -20px; opacity: 0.15; }
  }

  /* Floating glass cards */
  .float-card {
    position: absolute;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.09);
    border-radius: 14px;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.18);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }
  .fc-bar {
    border-radius: 4px;
    flex-shrink: 0;
  }
  .fc-bar--md { height: 10px; background: rgba(255,255,255,0.14); }
  .fc-bar--sm { height:  8px; background: rgba(255,255,255,0.08); }

  /* Left cards */
  .fc-1 { width: 190px; left: 2.8%;  top: 140px; rotate: 5deg;  animation: card-float  9s ease-in-out infinite; }
  .fc-2 { width: 170px; left: 6.9%;  top: 350px; rotate: -6deg; animation: card-float 11s ease-in-out infinite 1.5s; }
  .fc-3 { width: 160px; left: 1.4%;  top: 530px; rotate: 3deg;  animation: card-float 13s ease-in-out infinite 3s; }
  /* Right cards */
  .fc-4 { width: 170px; right: 13%; top:  50px; rotate: -7deg; animation: card-float 10s ease-in-out infinite 0.8s; }
  .fc-5 { width: 150px; right: 10%; top: 310px; rotate: 5deg;  animation: card-float 8.5s ease-in-out infinite 2.2s; }
  .fc-6 { width: 165px; right: 14%; top: 580px; rotate: -3deg; animation: card-float 12s ease-in-out infinite 4.5s; }
  @keyframes card-float {
    0%, 100% { translate: 0 0; }
    50%       { translate: 0 -14px; }
  }

  /* Decorative lines */
  .deco-line {
    position: absolute;
    height: 0;
    border-top: 1px solid rgba(255,255,255,0.14);
  }
  .dl-1 { width: 120px; left: 13.9%; top: 280px; rotate:  25deg; opacity: 0.5; }
  .dl-2 { width: 100px; left: 10.4%; top: 480px; rotate: -15deg; opacity: 0.4; }
  .dl-3 { width: 110px; right: 9.7%; top: 270px; rotate: -20deg; opacity: 0.5; }
  .dl-4 { width:  90px; right:11.1%; top: 470px; rotate:  18deg; opacity: 0.4; }

  /* Decorative icons */
  .deco-icon {
    position: absolute;
  }
  .di-1 { color: #00E5FF; opacity: 0.6; left: 81.9%; top:  60px; animation: icon-drift 11s ease-in-out infinite; }
  .di-2 { color: #7B61FF; opacity: 0.4; left:   18%;  top: 300px; animation: icon-drift 13s ease-in-out infinite 2s; }
  .di-3 { color: #FB3079; opacity: 0.5; left: 80.6%; top: 620px; animation: icon-drift  9s ease-in-out infinite 1s; }
  .di-4 { color: #00E5FF; opacity: 0.3; left: 18.75%; top: 70px; animation: icon-drift 14s ease-in-out infinite 3s; }
  @keyframes icon-drift {
    0%, 100% { translate: 0 0;    rotate:  0deg; }
    33%       { translate: 4px -8px;  rotate:  5deg; }
    66%       { translate: -4px -4px; rotate: -3deg; }
  }

  /* Accent squares */
  .acc-sq {
    position: absolute;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
  }
  .as-1 { width:34px; height:34px; left:19.4%; top:180px; border-radius:7px; opacity:0.45; rotate: 15deg; animation: acc-drift 16s ease-in-out infinite; }
  .as-2 { width:38px; height:38px; left:79.9%; top:500px; border-radius:8px; opacity:0.4;  rotate:-12deg; animation: acc-drift 12s ease-in-out infinite 3s; }
  .as-3 { width:30px; height:30px; left:17.4%; top:600px; border-radius:6px; opacity:0.5;  rotate: 22deg; animation: acc-drift 18s ease-in-out infinite 6s; }
  @keyframes acc-drift {
    0%, 100% { translate: 0 0; }
    25%       { translate:  5px -10px; }
    75%       { translate: -5px  -5px; }
  }

  /* ── Abstract Lottie layer ─────────────────────────── */
  /* The source animation paints everything in #150529 (near-black), so we
     invert + hue-rotate to get a bright cyan-leaning render that reads on
     the dark hero bg without fighting the CTAs. */
  .hero-lottie {
    position: absolute;
    top: 50%;
    left: 50%;
    width: min(1100px, 95vw);
    aspect-ratio: 1 / 1;
    translate: -50% -50%;
    opacity: 0;
    pointer-events: none;
    filter: invert(1) hue-rotate(170deg) saturate(0.85) brightness(0.85);
    transition: opacity 1.4s ease-out;
  }
  .hero-lottie.is-ready { opacity: 0.22; }
  .hero-lottie svg { display: block; width: 100%; height: 100%; }
  @media (prefers-reduced-motion: reduce) {
    .hero-lottie { display: none; }
  }

  /* ── Hero content ──────────────────────────────────── */
  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 860px;
    width: 100%;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  /* Eyebrow */
  .hero-eyebrow {
    display: inline-block;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #00E5FF;
    margin-bottom: 24px;
  }

  /* Headline */
  .hero-headline {
    font-size: clamp(46px, 6.5vw, 72px);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin: 0 0 32px;
  }
  .hl-line  { display: block; }
  .hl-white { color: var(--text); }
  .hl-cyan  { color: #00E5FF; }

  /* ── Word-flip slot machine ────────────────────────── */
  .word-flip-wrap {
    display: inline-block;
    overflow: hidden;
    height: 1.2em;
    clip-path: inset(0 0 0 0);
    vertical-align: bottom;
    position: relative;
    padding: 0.05em 0;
    margin: 0.06em 0;
  }
  .word-flip-track {
    display: flex;
    flex-direction: column;
    will-change: transform;
  }
  .word-flip-item {
    display: block;
    line-height: 1.2em;
    height: 1.2em;
    overflow: hidden;
    white-space: nowrap;
  }

  /* The slide-up transition, applied via JS class toggle */
  .word-flip-track.is-animating {
    transition: transform 0.52s cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* After snap (no transition for instant reset) */
  .word-flip-track.no-transition {
    transition: none;
  }

  /* Subtext */
  .hero-sub {
    font-size: 18px;
    color: var(--muted);
    max-width: 580px;
    line-height: 1.65;
    margin: 0 0 40px;
  }

  /* CTA area */
  .hero-ctas {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  /* Primary button */
  .btn-hero-join {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 16px 36px;
    background: linear-gradient(180deg, #00E5FF 0%, #00B4D8 100%);
    color: #07090F;
    border: none;
    border-radius: 10px;
    font-family: var(--font-primary);
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
    box-shadow: 0 4px 24px rgba(0,229,255,0.30);
    transition: box-shadow 0.3s ease, filter 0.2s ease, transform 0.1s ease;
  }
  .btn-hero-join:hover {
    filter: brightness(1.06);
    box-shadow: 0 6px 32px rgba(0,229,255,0.45);
  }
  .btn-hero-join:active { transform: scale(0.98); }
  .btn-arrow { flex-shrink: 0; }

  /* Secondary links */
  .hero-links {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .hero-link-divider {
    width: 1px;
    height: 16px;
    background: rgba(255,255,255,0.15);
    flex-shrink: 0;
  }
  .hero-link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 14px;
    font-weight: 600;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .hl-emoji { font-size: 13px; line-height: 1; }
  .hl-text {
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--muted) 35%, transparent);
    text-underline-offset: 3px;
    transition: text-decoration-color 0.2s ease;
  }
  .hl-badge {
    font-style: normal;
    font-size: 9px;
    font-weight: 700;
    color: #FF7A30;
    background: rgba(255,122,48,0.12);
    border-radius: 4px;
    padding: 2px 6px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .hero-link:hover { color: var(--text); }
  .hero-link:hover .hl-text {
    text-decoration-color: color-mix(in srgb, var(--text) 50%, transparent);
  }

  /* ── Mission ──────────────────────────────────────── */
  .mission-card {
    padding: var(--pad-lg);
  }

  .mission-card h2 {
    font-size: clamp(22px, 3vw, 30px);
    margin: 12px 0 24px;
    line-height: 1.25;
  }

  .mission-body {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* ── Pillars ──────────────────────────────────────── */
  .section-sub {
    color: var(--muted);
    font-size: 15px;
    margin-top: 8px;
    margin-bottom: 32px;
  }

  .pillars-header {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 40px;
    text-align: left;
  }

  .pillars-title {
    font-size: clamp(28px, 4.6vw, 44px);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--text);
    margin: 0;
  }

  .pillars-sub {
    font-size: clamp(14px, 1.4vw, 16px);
    color: var(--muted);
    margin: 0;
    max-width: 620px;
    line-height: 1.6;
  }

  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .pillar-card {
    position: relative;
    overflow: hidden;
    padding: 36px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    transition:
      transform 0.5s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.3s ease,
      box-shadow 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .pillar-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at top left, var(--pillar-accent, transparent) 0%, transparent 55%);
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }
  .pillar-card > * { position: relative; z-index: 1; }

  .pillar-card--mind   { --pillar-color: #00E5FF; --pillar-accent: rgba(0, 229, 255, 0.10); }
  .pillar-card--body   { --pillar-color: #7B61FF; --pillar-accent: rgba(123, 97, 255, 0.10); }
  .pillar-card--soul   { --pillar-color: #FB3079; --pillar-accent: rgba(251, 48, 121, 0.10); }
  .pillar-card--pocket { --pillar-color: #00E5FF; --pillar-accent: rgba(0, 229, 255, 0.10); }

  .pillar-icon {
    width: 52px;
    height: 52px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 14px;
    background: color-mix(in srgb, var(--pillar-color) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--pillar-color) 22%, transparent);
    color: var(--pillar-color);
    flex-shrink: 0;
    transition:
      transform 0.5s cubic-bezier(0.22, 1, 0.36, 1),
      background 0.4s ease,
      border-color 0.4s ease;
  }

  .pillar-body {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .pillar-card h3 {
    font-size: 22px;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.01em;
    margin: 0;
    line-height: 1.2;
  }

  .pillar-card p {
    font-size: 15px;
    color: var(--muted);
    line-height: 1.65;
    margin: 0;
  }

  @media (hover: hover) {
    .pillar-card:hover {
      transform: translateY(-4px);
      border-color: color-mix(in srgb, var(--pillar-color) 32%, var(--gb));
      box-shadow: 0 14px 36px rgba(0, 0, 0, 0.35);
    }
    .pillar-card:hover::before { opacity: 1; }
    .pillar-card:hover .pillar-icon {
      transform: scale(1.06) rotate(-3deg);
      background: color-mix(in srgb, var(--pillar-color) 18%, transparent);
      border-color: color-mix(in srgb, var(--pillar-color) 38%, transparent);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pillar-card, .pillar-icon { transition: none !important; }
    .pillar-card:hover { transform: none !important; }
    .pillar-card:hover .pillar-icon { transform: none !important; }
  }

  /* ── Proof / Metrics grid ─────────────────────────── */
  .proof-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  /* 6-up row only when there's genuinely room for each card's content */
  @media (min-width: 1200px) {
    .proof-grid {
      grid-template-columns: repeat(6, minmax(0, 1fr));
      gap: 16px;
    }
  }

  .stat-card {
    position: relative;
    overflow: hidden;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 28px 16px;
    border: 1px solid var(--gb);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.02);
    text-align: center;
    transition:
      transform 0.5s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.3s ease,
      box-shadow 0.5s cubic-bezier(0.22, 1, 0.36, 1),
      background 0.4s ease;
  }

  .stat-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(0, 229, 255, 0.10) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }

  /* Top hairline accent that grows in on hover */
  .stat-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    width: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, #00E5FF, transparent);
    transform: translateX(-50%);
    transition: width 0.6s cubic-bezier(0.22, 1, 0.36, 1);
    pointer-events: none;
  }

  .stat-card > * { position: relative; z-index: 1; }

  .stat-number {
    font-size: clamp(20px, 1.9vw, 26px);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1;
    color: #00E5FF;
    white-space: nowrap;
    display: inline-flex;
    align-items: baseline;
    gap: 0.15em;
    max-width: 100%;
  }

  .stat-arrow {
    display: inline-block;
    color: #00E5FF;
    opacity: 0.7;
    transform: translateY(-0.04em);
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.3s ease;
  }

  .stat-label {
    font-size: 12px;
    font-weight: 600;
    color: var(--muted);
    text-transform: none;
    letter-spacing: 0.02em;
    line-height: 1.35;
    max-width: 14ch;
  }

  @media (hover: hover) {
    .stat-card:hover {
      transform: translateY(-3px);
      border-color: rgba(0, 229, 255, 0.28);
      box-shadow: 0 10px 32px rgba(0, 0, 0, 0.32);
      background: rgba(0, 229, 255, 0.025);
    }
    .stat-card:hover::before { opacity: 1; }
    .stat-card:hover::after { width: 70%; }
    .stat-card:hover .stat-arrow {
      transform: translate(4px, -0.04em);
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .stat-card, .stat-card::after, .stat-arrow { transition: none !important; }
    .stat-card:hover { transform: none !important; }
  }

  /* ── Work mosaic gallery ──────────────────────────── */
  .work-mosaic-header {
    text-align: left;
    margin-bottom: 32px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .pill-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    align-self: flex-start;
    padding: 6px 16px;
    background: rgba(251, 48, 121, 0.08);
    border: 1px solid rgba(251, 48, 121, 0.19);
    border-radius: 100px;
    font-family: var(--font-primary);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: #FB3079;
    text-transform: uppercase;
  }
  .pill-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #FB3079;
    box-shadow: 0 0 8px rgba(251, 48, 121, 0.55);
  }

  .work-mosaic-title {
    font-size: clamp(28px, 4.6vw, 44px);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--text);
    margin: 0;
  }

  .work-mosaic-sub {
    font-size: clamp(14px, 1.4vw, 16px);
    color: var(--muted);
    margin: 0;
    max-width: 560px;
    line-height: 1.55;
  }

  .mosaic-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    grid-template-rows: minmax(0, 380px) minmax(0, 280px);
    gap: 8px;
  }

  /* Card 1 (LAB) — wide top-left | Card 2 (Rob) — top-right
     Cards 3,4,5 — bottom row spanning all columns */
  .mosaic-card:nth-child(1) { grid-column: 1; grid-row: 1; }
  .mosaic-card:nth-child(2) { grid-column: 2; grid-row: 1; }
  .mosaic-card:nth-child(3),
  .mosaic-card:nth-child(4),
  .mosaic-card:nth-child(5) { grid-row: 2; }

  /* Bottom row uses sub-grid to get equal thirds spanning the full width */
  .mosaic-grid::after {
    content: none;
  }

  /* Re-layout: bottom row needs three equal cards across both columns.
     Easiest: switch to two stacked grids via grid-template-areas. */
  .mosaic-grid {
    grid-template-columns: repeat(6, 1fr);
    grid-template-areas:
      "a a a a b b"
      "c c d d e e";
  }
  .mosaic-card:nth-child(1) { grid-area: a; }
  .mosaic-card:nth-child(2) { grid-area: b; }
  .mosaic-card:nth-child(3) { grid-area: c; }
  .mosaic-card:nth-child(4) { grid-area: d; }
  .mosaic-card:nth-child(5) { grid-area: e; }

  .mosaic-card {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-card, 14px);
    border: 1px solid var(--gb);
    text-decoration: none;
    color: inherit;
    background: rgba(255, 255, 255, 0.02);
    isolation: isolate;
    transform: translateZ(0);
    transition:
      transform 0.5s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.5s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.4s ease;
  }
  .mosaic-card img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    transition: transform 0.9s cubic-bezier(0.22, 1, 0.36, 1), filter 0.5s ease;
    filter: saturate(0.96);
  }
  .mosaic-card::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      180deg,
      rgba(7, 9, 15, 0) 0%,
      rgba(7, 9, 15, 0) 30%,
      rgba(7, 9, 15, 0.85) 100%
    );
    transition: opacity 0.4s ease;
    pointer-events: none;
  }
  .mosaic-card::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 2;
    background: radial-gradient(
      ellipse at 50% 100%,
      rgba(0, 229, 255, 0.18) 0%,
      transparent 65%
    );
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }

  .mosaic-overlay {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    height: 100%;
    padding: 28px;
    gap: 6px;
  }

  .mosaic-card:not(.mosaic-card--wide) .mosaic-overlay {
    padding: 22px;
  }

  .mosaic-tag {
    display: inline-block;
    align-self: flex-start;
    padding: 4px 10px;
    border-radius: 100px;
    background: rgba(255, 255, 255, 0.10);
    border: 1px solid rgba(255, 255, 255, 0.16);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #fff;
    margin-bottom: 6px;
    transform: translateY(6px);
    opacity: 0;
    transition:
      transform 0.5s cubic-bezier(0.22, 1, 0.36, 1) 0.05s,
      opacity 0.5s ease 0.05s;
  }

  .mosaic-title {
    font-size: clamp(20px, 2.4vw, 28px);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #fff;
    margin: 0;
    transform: translateY(8px);
    transition: transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .mosaic-meta {
    font-size: 13px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.72);
    margin: 0;
    opacity: 0.9;
    transform: translateY(8px);
    transition:
      transform 0.55s cubic-bezier(0.22, 1, 0.36, 1) 0.04s,
      opacity 0.4s ease 0.04s;
  }

  .mosaic-arrow {
    position: absolute;
    top: 22px;
    right: 22px;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.18);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
