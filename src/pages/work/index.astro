---
import Base from '../../layouts/Base.astro';
import { sanity } from '../../lib/sanity';
import { CASE_LIST_QUERY } from '../../lib/queries';

let sanityCases: any[] | null = null;
try {
  const result = await sanity.fetch(CASE_LIST_QUERY);
  sanityCases = Array.isArray(result) && result.length > 0 ? result : null;
} catch {
  sanityCases = null;
}

const HARDCODED_CASES = [
  {
    href: '/work/rob-dial',
    tagClass: 'tag',
    category: 'Podcast Host',
    client: 'Rob Dial',
    description: 'Scaled a one-person media role into a full content operation. Revenue grew from $1M to $5M.',
    statNum: '10x',
    statLabel: 'Content output',
  },
  {
    href: '/work/the-lab-miami',
    tagClass: 'tag tag-purple',
    category: 'Builder Hub',
    client: 'The LAB Miami',
    description: 'Built content infrastructure and positioning clarity for a globally connected innovation campus.',
    statNum: '30%',
    statLabel: 'Faster sales cycles',
  },
  {
    href: '/work/raasin-in-the-sun',
    tagClass: 'tag tag-pink',
    category: 'Non-Profit',
    client: 'Raasin in the Sun',
    description: 'Documented 9 public art projects, secured six-figure grants, built media foundation of a creative placemaking movement.',
    statNum: '6-fig',
    statLabel: 'Grants secured',
  },
  {
    href: '/work/dawa',
    tagClass: 'tag tag-pink',
    category: 'Non-Profit',
    client: 'DAWA',
    description: "Found the organization's anchor phrase, built its content system, and co-built an education program from zero.",
    statNum: '80%',
    statLabel: 'Messaging clarity',
  },
  {
    href: '/work/stephy-lee',
    tagClass: 'tag',
    category: 'Creative Founder',
    client: 'Stephy Lee',
    description: "Protected a music artist's brand during crisis, raised $30K, and strategically secured an SXSW booking.",
    statNum: 'SXSW',
    statLabel: 'Stage secured',
  },
  {
    href: '/work/spraycation',
    tagClass: 'tag tag-purple',
    category: 'Experiential',
    client: 'SPRAYCATION',
    description: 'Built the brand foundation and operational backbone for a female-led experiential art movement while the tour was live.',
    statNum: '6 cities',
    statLabel: 'Tour executed',
  },
  {
    href: '/work/lifes-tapestry',
    tagClass: 'tag tag-pink',
    category: 'Lifelong Dream',
    client: "Life's Tapestry",
    description: 'Launched a digital property for a 64-year-old first-time writer — 25+ editions and a growing audience.',
    statNum: '47',
    statLabel: 'Real subscribers',
  },
  {
    href: '/work/pay-the-creators',
    tagClass: 'tag',
    category: 'Podcast',
    client: 'Pay the Creators (BeatStars)',
    description: "Renamed and repositioned a podcast to align with BeatStars' brand mission. Built the first 7 episodes.",
    statNum: '1',
    statLabel: 'Costly mistake stopped',
  },
];

const cases = sanityCases
  ? sanityCases.map((c) => ({
      href: `/work/${c.slug}`,
      tagClass: c.tagClass ?? 'tag',
      category: c.category ?? '',
      client: c.client ?? '',
      description: c.cardDescription ?? '',
      statNum: c.cardStat?.num ?? '',
      statLabel: c.cardStat?.label ?? '',
    }))
  : HARDCODED_CASES;
---

<Base
  title="The Work — CWK. Experience"
  description="Brands built for the real world. A collection of CWK. work bridging education, community, tech, and art."
>
  <!-- ── Hero ──────────────────────────────────────────────── -->
  <section class="work-hero">
    <div class="work-hero-inner">
      <span class="eyebrow fade-up">The Work</span>
      <h1 class="fade-up fade-up-delay-1">Brands Built For The Real World.</h1>
      <p class="hero-sub fade-up fade-up-delay-2">
        A collection of work bridging education, community, tech, &amp; art.
      </p>
    </div>
  </section>

  <!-- ── Case Study Grid ───────────────────────────────────── -->
  <section class="section cases-section">
    <div class="section-inner">
      <div class="cases-grid">
        {cases.map((c, i) => (
          <a href={c.href} class={`case-card glass-card fade-up`} style={`animation-delay: ${i * 0.05}s`}>
            <span class={c.tagClass}>{c.category}</span>
            <h2 class="case-client">{c.client}</h2>
            <p class="case-desc">{c.description}</p>
            <div class="case-result">
              <span class="case-stat gradient-text">{c.statNum}</span>
              <span class="case-stat-label">{c.statLabel}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── The Platform ──────────────────────────────────────── -->
  <section class="section work-platform">
    <div class="section-inner">
      <div class="wp-inner">
        <span class="wp-eyebrow">THE PLATFORM</span>
        <h2 class="wp-heading">See what's inside CWK. Agent+</h2>
        <p class="wp-sub">
          Your personal command center for managing relationships, tracking momentum,
          and executing with clarity. Built on the PLOS framework. Powered by humans who power AI.
        </p>
        <a href="/product" class="wp-cta">
          Explore the Product
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
        <ul class="wp-badges">
          <li class="wp-badge wp-badge--cyan">Player Dashboard</li>
          <li class="wp-badge wp-badge--purple">Relationship Health</li>
          <li class="wp-badge wp-badge--cyan">Visual Deals</li>
          <li class="wp-badge wp-badge--pink">CWK. Agent+</li>
          <li class="wp-badge wp-badge--purple">Brand Destination</li>
          <li class="wp-badge wp-badge--cyan">Priority Actions</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ── CTA ───────────────────────────────────────────────── -->
  <section class="section cta-section">
    <div class="section-inner">
      <div class="cta-inner">
        <a href="/#waitlist" class="btn btn-primary">Join the Waitlist →</a>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ── Hero ─────────────────────────────────────────── */
  .work-hero {
    padding-top: 144px;
    padding-bottom: 64px;
    padding-left: 24px;
    padding-right: 24px;
    text-align: center;
  }

  .work-hero-inner {
    max-width: 680px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .work-hero-inner .eyebrow {
    margin-bottom: 16px;
  }

  .work-hero-inner h1 {
    font-size: clamp(32px, 5.5vw, 52px);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: var(--text);
    margin-bottom: 20px;
  }

  .hero-sub {
    font-size: 16px;
    color: var(--muted);
    max-width: 480px;
    line-height: 1.65;
  }

  /* ── Cases grid ───────────────────────────────────── */
  .cases-section {
    padding-top: 0;
  }

  .cases-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(16px, 2vw, 28px);
  }

  .case-card {
    padding: 28px 32px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    text-decoration: none;
    color: inherit;
  }

  .case-card:hover {
    /* glass-card already handles border brightening + scale;
       add a subtle translate for extra lift feeling */
    transform: translateY(-2px) scale(1.01);
  }

  .case-client {
    font-size: clamp(17px, 2.2vw, 22px);
    font-weight: 700;
    color: var(--text);
    margin-top: 4px;
    line-height: 1.2;
  }

  .case-desc {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.6;
    flex: 1;
  }

  .case-result {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-top: 4px;
    padding-top: 14px;
    border-top: 1px solid var(--gb);
  }

  .case-stat {
    font-size: 26px;
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .case-stat-label {
    font-size: 11px;
    color: var(--dim);
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }

  /* ── Platform teaser ──────────────────────────────── */
  .work-platform {
    padding-top: 96px;
    padding-bottom: 56px;
  }
  .wp-inner {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 20px;
  }
  .wp-eyebrow {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    background: linear-gradient(90deg, #00E5FF, #7B61FF);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .wp-heading {
    font-size: clamp(28px, 3.8vw, 44px);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: var(--text);
    margin: 0;
  }
  .wp-sub {
    font-size: 16px;
    color: var(--muted);
    line-height: 1.65;
    max-width: 560px;
    margin: 0;
  }
  .wp-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    background: linear-gradient(135deg, #00E5FF 0%, #7B61FF 100%);
    color: #07090F;
    border-radius: 10px;
    font-weight: 700;
    font-size: 15px;
    text-decoration: none;
    box-shadow: 0 4px 20px rgba(0, 229, 255, 0.28);
    transition: transform 0.2s ease, box-shadow 0.3s ease, filter 0.2s ease;
    margin-top: 8px;
  }
  .wp-cta:hover {
    filter: brightness(1.06);
    box-shadow: 0 6px 28px rgba(123, 97, 255, 0.38);
  }
  .wp-cta:active { transform: scale(0.98); }

  .wp-badges {
    list-style: none;
    padding: 0;
    margin: 16px 0 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px 12px;
  }
  .wp-badge {
    padding: 8px 18px;
    border-radius: 100px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border: 1px solid var(--badge-border, rgba(255,255,255,0.1));
    background: var(--badge-bg, rgba(255,255,255,0.02));
    color: var(--badge-color, var(--muted));
  }
  .wp-badge--cyan {
    --badge-color: #00E5FF;
    --badge-border: rgba(0, 229, 255, 0.35);
    --badge-bg: rgba(0, 229, 255, 0.06);
  }
  .wp-badge--purple {
    --badge-color: #7B61FF;
    --badge-border: rgba(123, 97, 255, 0.35);
    --badge-bg: rgba(123, 97, 255, 0.06);
  }
  .wp-badge--pink {
    --badge-color: #FB3079;
    --badge-border: rgba(251, 48, 121, 0.35);
    --badge-bg: rgba(251, 48, 121, 0.06);
  }

  /* ── CTA ──────────────────────────────────────────── */
  .cta-section {
    padding-top: 56px;
    padding-bottom: 16px;
  }

  .cta-inner {
    display: flex;
    justify-content: center;
  }

  /* ── Responsive ───────────────────────────────────── */
  @media (max-width: 768px) {
    .cases-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .work-hero {
      padding-top: 112px;
      padding-bottom: 48px;
    }

    .case-card {
      padding: 22px 20px;
    }
  }
</style>
