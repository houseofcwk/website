---
import Base from '../../layouts/Base.astro';
import PortableText from '../../components/PortableText.astro';
import { sanity, urlFor } from '../../lib/sanity';
import { CASE_BY_SLUG_QUERY } from '../../lib/queries';
import { CASE_STUDIES, CASE_STUDIES_BY_SLUG, isVisibleSlug, type CaseStudy } from '../../data/caseStudies';

export async function getStaticPaths() {
  return CASE_STUDIES
    .filter((c) => isVisibleSlug(c.slug))
    .map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const fallback = slug ? CASE_STUDIES_BY_SLUG[slug as string] : undefined;

let cms: any = null;
try {
  cms = await sanity.fetch(CASE_BY_SLUG_QUERY, { slug });
} catch {
  cms = null;
}

if (!cms && !fallback) {
  throw new Error(`Case study not found: ${slug}`);
}

// CMS values take priority over fallback when present.
const cs: CaseStudy & { body: any[] } = {
  ...(fallback ?? ({} as CaseStudy)),
  ...(cms ?? {}),
} as any;

let cardImage: string | undefined = fallback?.cardImage;
if (cms?.cardImage?.asset) {
  try {
    cardImage = urlFor(cms.cardImage).width(1600).auto('format').url();
  } catch {
    /* keep fallback */
  }
}

const body = (cms?.body && cms.body.length > 0) ? cms.body : (fallback?.body ?? []);
const stats = (cms?.stats && cms.stats.length > 0) ? cms.stats : (fallback?.stats ?? []);
const testimonial = cms?.testimonial ?? fallback?.testimonial;

const pageTitle = cs.seo?.title ?? `${cs.client} | CWK. Case Study`;
const pageDescription = cs.seo?.description ?? cs.cardDescription ?? '';
---

<Base title={pageTitle} description={pageDescription}>
  <!-- ── Hero ───────────────────────────────────────────────── -->
  <section class="csd-hero">
    <div class="csd-hero-inner">
      <a href="/case-studies" class="csd-back">← All Case Studies</a>
      <span class="csd-eyebrow">{cs.category}</span>
      <h1 class="csd-headline">{cs.headline ?? cs.client}</h1>
      {cs.tagline && <p class="csd-tagline">{cs.tagline}</p>}
      <div class="csd-meta">
        <span class="csd-client">{cs.client}</span>
        {cs.duration && <><span class="csd-sep">·</span><span class="csd-duration">{cs.duration}</span></>}
        {cs.result && cs.resultLabel && (
          <><span class="csd-sep">·</span>
          <span class="csd-result-pill">
            <span class="csd-result-num">{cs.result}</span>
            <span class="csd-result-lbl">{cs.resultLabel}</span>
          </span></>
        )}
      </div>
    </div>
  </section>

  {cardImage && (
    <section class="csd-cover">
      <div class="csd-cover-inner">
        <img src={cardImage} alt={cs.cardImageAlt ?? cs.client} loading="eager" decoding="async" />
      </div>
    </section>
  )}

  {stats && stats.length > 0 && (
    <section class="csd-stats">
      <div class="csd-stats-inner">
        {stats.map((s: any) => (
          <div class="csd-stat">
            <span class="csd-stat-value">{s.value}</span>
            <span class="csd-stat-label">{s.label}</span>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- ── Body ───────────────────────────────────────────────── -->
  <article class="csd-body">
    <div class="csd-body-inner">
      <PortableText value={body} />
    </div>
  </article>

  {testimonial?.quote && (
    <section class="csd-testimonial">
      <div class="csd-testimonial-inner">
        <blockquote>
          <p>"{testimonial.quote}"</p>
          <footer>– {testimonial.author}{testimonial.role ? `, ${testimonial.role}` : ''}</footer>
        </blockquote>
      </div>
    </section>
  )}

  <section class="csd-back-nav">
    <div class="section-inner">
      <a href="/case-studies" class="btn btn-ghost">← Back to All Case Studies</a>
    </div>
  </section>

  <!-- ── Player X-Ray CTA ───────────────────────────────────── -->
  <section id="player-xray" class="section csd-waitlist csd-xray">
    <div class="section-inner">
      <span class="eyebrow">Player X-Ray</span>
      <h2>The right infrastructure starts with knowing what kind of player you are.</h2>
      <p class="csd-waitlist-sub">
        Take the X-Ray. Five questions. Free. Walk away knowing exactly where you
        are and the right level to start building from.
      </p>

      <ul class="csd-xray-pills" aria-label="What you get">
        <li class="csd-xray-pill"><span class="csd-xray-pill-dot"></span>Free</li>
        <li class="csd-xray-pill"><span class="csd-xray-pill-dot"></span>5 questions</li>
        <li class="csd-xray-pill"><span class="csd-xray-pill-dot"></span>Long-term clarity</li>
      </ul>

      <a href="/brand-mirror" class="csd-xray-cta">
        Take the X-Ray
        <svg class="csd-xray-cta-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- ── Image lightbox ─────────────────────────────────────── -->
  <dialog id="csd-lightbox" class="csd-lightbox" aria-label="Image viewer">
    <button type="button" class="csd-lightbox-close" aria-label="Close image">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
      </svg>
    </button>
    <figure class="csd-lightbox-figure">
      <img alt="" />
      <figcaption hidden></figcaption>
    </figure>
  </dialog>

  <script>
    const dialog = document.getElementById('csd-lightbox') as HTMLDialogElement | null;
    if (dialog) {
      const fig = dialog.querySelector('figure') as HTMLElement;
      const dialogImg = dialog.querySelector('img') as HTMLImageElement;
      const dialogCap = dialog.querySelector('figcaption') as HTMLElement;
      const closeBtn = dialog.querySelector('.csd-lightbox-close') as HTMLButtonElement;

      const open = (img: HTMLImageElement) => {
        dialogImg.src = img.currentSrc || img.src;
        dialogImg.alt = img.alt || '';
        const sourceFig = img.closest('figure');
        const cap = sourceFig?.querySelector('figcaption');
        if (cap && cap.textContent && cap.textContent.trim().length > 0) {
          dialogCap.textContent = cap.textContent.trim();
          dialogCap.hidden = false;
        } else {
          dialogCap.textContent = '';
          dialogCap.hidden = true;
        }
        dialog.showModal();
        document.body.style.overflow = 'hidden';
      };

      const close = () => {
        if (dialog.open) dialog.close();
        document.body.style.overflow = '';
      };

      // Bind clicks on body + cover images.
      const targets = document.querySelectorAll<HTMLImageElement>('.csd-body img, .csd-cover img');
      targets.forEach((img) => {
        img.style.cursor = 'zoom-in';
        img.addEventListener('click', (e) => {
          e.preventDefault();
          open(img);
        });
      });

      closeBtn.addEventListener('click', close);

      // Click on backdrop (anywhere outside the figure) closes.
      dialog.addEventListener('click', (e) => {
        if (e.target instanceof Node && !fig.contains(e.target)) {
          close();
        }
      });

      // Native ESC fires the cancel event; ensure scroll restores.
      dialog.addEventListener('close', () => {
        document.body.style.overflow = '';
      });
    }
  </script>
</Base>

<style>
  /* ── Hero ─────────────────────────────────────────────────── */
  .csd-hero {
    padding: 120px 24px 36px;
  }
  .csd-hero-inner {
    max-width: 880px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .csd-back {
    align-self: flex-start;
    color: var(--muted);
    font-size: 13px;
    text-decoration: none;
    margin-bottom: 4px;
  }
  .csd-back:hover { color: var(--cyan); }
  .csd-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--cyan);
  }
  .csd-headline {
    margin: 0;
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--text);
  }
  .csd-tagline {
    margin: 0;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--cyan);
    font-style: italic;
  }
  .csd-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    color: var(--muted);
    margin-top: 4px;
  }
  .csd-sep { color: var(--dim); }
  .csd-result-pill {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    padding: 4px 10px;
    border: 1px solid rgba(0, 229, 255, 0.25);
    background: rgba(0, 229, 255, 0.08);
    border-radius: 100px;
  }
  .csd-result-num {
    font-weight: 800;
    color: var(--cyan);
  }
  .csd-result-lbl {
    font-size: 11px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }

  /* ── Cover image ──────────────────────────────────────────── */
  .csd-cover {
    padding: 8px 24px 16px;
  }
  .csd-cover-inner {
    max-width: 1080px;
    margin: 0 auto;
    border-radius: 18px;
    overflow: hidden;
    border: 1px solid var(--gb);
    background: rgba(255, 255, 255, 0.02);
  }
  .csd-cover-inner img {
    display: block;
    width: 100%;
    height: auto;
    max-height: 85vh;
    object-fit: contain;
  }

  /* ── Stats ────────────────────────────────────────────────── */
  .csd-stats {
    padding: 24px;
  }
  .csd-stats-inner {
    max-width: 880px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 14px;
  }
  .csd-stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 18px 20px;
    border: 1px solid var(--gb);
    border-radius: 14px;
    background: rgba(255,255,255,0.02);
  }
  .csd-stat-value {
    font-size: clamp(22px, 2.5vw, 28px);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--cyan);
    line-height: 1;
  }
  .csd-stat-label {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--dim);
  }

  /* ── Body ─────────────────────────────────────────────────── */
  .csd-body {
    padding: 24px 24px 56px;
  }
  .csd-body-inner {
    max-width: 760px;
    margin: 0 auto;
  }
  .csd-body-inner :global(h2) {
    margin: 36px 0 14px;
    font-size: clamp(22px, 2.4vw, 26px);
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.015em;
  }
  .csd-body-inner :global(h2:first-child) { margin-top: 0; }
  .csd-body-inner :global(h3) {
    margin: 24px 0 10px;
    font-size: 18px;
    font-weight: 700;
    color: var(--text);
  }
  .csd-body-inner :global(p) {
    margin: 0 0 14px;
    font-size: 16px;
    line-height: 1.7;
    color: var(--muted);
  }
  .csd-body-inner :global(ul),
  .csd-body-inner :global(ol) {
    padding-left: 22px;
    margin: 0 0 18px;
    color: var(--muted);
  }
  .csd-body-inner :global(li) {
    margin: 0 0 8px;
    line-height: 1.65;
  }
  .csd-body-inner :global(a) { color: var(--cyan); }
  .csd-body-inner :global(blockquote) {
    margin: 24px 0;
    padding-left: 16px;
    border-left: 2px solid var(--cyan);
    color: var(--text);
    font-style: italic;
  }

  /* PortableText custom blocks */
  .csd-body-inner :global(.cs-figure) {
    margin: 28px 0;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid var(--gb);
    background: rgba(0,0,0,0.25);
  }
  .csd-body-inner :global(.cs-figure img) {
    display: block;
    width: 100%;
    height: auto;
  }
  .csd-body-inner :global(.cs-figure figcaption) {
    padding: 10px 14px;
    font-size: 12.5px;
    color: var(--dim);
    border-top: 1px solid var(--gb);
  }

  .csd-body-inner :global(.cs-gallery) {
    display: grid;
    gap: 14px;
    margin: 28px 0;
  }
  .csd-body-inner :global(.cs-gallery--cols-3) { grid-template-columns: repeat(3, 1fr); }
  .csd-body-inner :global(.cs-gallery--cols-2) { grid-template-columns: repeat(2, 1fr); }
  .csd-body-inner :global(.cs-gallery--cols-1) { grid-template-columns: 1fr; }
  @media (max-width: 720px) {
    .csd-body-inner :global(.cs-gallery--cols-3),
    .csd-body-inner :global(.cs-gallery--cols-2) { grid-template-columns: 1fr; }
  }
  .csd-body-inner :global(.cs-gallery-item) {
    margin: 0;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--gb);
  }
  .csd-body-inner :global(.cs-gallery-item img) {
    display: block;
    width: 100%;
    height: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }
  /* Single-column gallery: let images keep their natural aspect ratio */
  .csd-body-inner :global(.cs-gallery--cols-1 .cs-gallery-item img) {
    aspect-ratio: auto;
    height: auto;
    max-height: 80vh;
    object-fit: contain;
    background: rgba(255, 255, 255, 0.02);
  }

  .csd-body-inner :global(.cs-video) {
    margin: 28px 0;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid var(--gb);
  }
  .csd-body-inner :global(.cs-video-frame) {
    position: relative;
    aspect-ratio: 16 / 9;
    background: #000;
  }
  .csd-body-inner :global(.cs-video-frame iframe) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
  .csd-body-inner :global(.cs-video figcaption) {
    padding: 10px 14px;
    font-size: 12.5px;
    color: var(--dim);
    border-top: 1px solid var(--gb);
  }

  .csd-body-inner :global(.cs-callout) {
    margin: 28px 0;
    padding: 22px 26px;
    border-radius: 14px;
    border: 1px solid var(--gb);
    background: rgba(255,255,255,0.02);
  }
  .csd-body-inner :global(.cs-callout--quote) {
    border-left: 3px solid var(--cyan);
  }
  .csd-body-inner :global(.cs-callout p) {
    margin: 0 0 8px;
    color: var(--text);
    font-size: 17px;
    line-height: 1.55;
  }
  .csd-body-inner :global(.cs-callout cite) {
    font-size: 13px;
    color: var(--dim);
    font-style: normal;
  }

  /* ── Testimonial ─────────────────────────────────────────── */
  .csd-testimonial {
    padding: 0 24px 48px;
  }
  .csd-testimonial-inner {
    max-width: 760px;
    margin: 0 auto;
    border-left: 3px solid var(--cyan);
    padding: 18px 22px;
    background: rgba(0,229,255,0.04);
    border-radius: 0 12px 12px 0;
  }
  .csd-testimonial-inner blockquote {
    margin: 0;
    padding: 0;
    border: 0;
  }
  .csd-testimonial-inner p {
    margin: 0 0 8px;
    font-size: 18px;
    line-height: 1.55;
    color: var(--text);
    font-style: italic;
  }
  .csd-testimonial-inner footer {
    font-size: 13px;
    color: var(--dim);
  }

  /* ── Back nav + waitlist ─────────────────────────────────── */
  .csd-back-nav {
    padding: 32px 24px 0;
  }
  .csd-waitlist {
    text-align: center;
  }
  .csd-waitlist h2 {
    margin: 12px 0 8px;
  }
  .csd-waitlist-sub {
    color: var(--muted);
    max-width: 560px;
    margin: 0 auto 24px;
  }

  /* Player X-Ray pills */
  .csd-xray-pills {
    list-style: none;
    margin: 0 auto 28px;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px 10px;
  }
  .csd-xray-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 14px;
    background: rgba(0, 229, 255, 0.06);
    border: 1px solid rgba(0, 229, 255, 0.22);
    border-radius: 100px;
    font-size: 12.5px;
    font-weight: 600;
    letter-spacing: 0.01em;
    color: var(--text);
  }
  .csd-xray-pill-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--cyan);
    box-shadow: 0 0 8px rgba(0, 229, 255, 0.55);
  }

  /* Take the X-Ray button */
  .csd-xray-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    background: linear-gradient(135deg, #00E5FF 0%, #7B61FF 100%);
    color: #07090F;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.005em;
    text-decoration: none;
    box-shadow: 0 6px 28px rgba(0, 229, 255, 0.25);
    transition: box-shadow 0.3s ease, transform 0.1s ease, filter 0.2s ease;
  }
  .csd-xray-cta:hover {
    filter: brightness(1.06);
    box-shadow: 0 10px 36px rgba(123, 97, 255, 0.34);
  }
  .csd-xray-cta:active { transform: scale(0.985); }
  .csd-xray-cta-arrow {
    transition: transform 0.25s ease;
    flex-shrink: 0;
  }
  .csd-xray-cta:hover .csd-xray-cta-arrow { transform: translateX(3px); }

  /* ── Lightbox ─────────────────────────────────────────────── */
  .csd-lightbox {
    border: 0;
    padding: 0;
    margin: auto;
    max-width: 100vw;
    max-height: 100vh;
    width: 100vw;
    height: 100vh;
    background: transparent;
    color: var(--text);
  }
  .csd-lightbox::backdrop {
    background: rgba(8, 10, 16, 0.86);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
  .csd-lightbox[open] {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .csd-lightbox-figure {
    margin: 0;
    padding: 32px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    max-width: 92vw;
    max-height: 92vh;
  }
  .csd-lightbox-figure img {
    display: block;
    max-width: 100%;
    max-height: 80vh;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 10px;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.6);
    cursor: default;
  }
  .csd-lightbox-figure figcaption {
    max-width: 720px;
    text-align: center;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.5;
  }
  .csd-lightbox-close {
    position: fixed;
    top: 18px;
    right: 18px;
    width: 42px;
    height: 42px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(20, 22, 28, 0.65);
    color: #fff;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease, transform 0.15s ease;
  }
  .csd-lightbox-close:hover {
    background: rgba(40, 44, 56, 0.85);
    border-color: rgba(255, 255, 255, 0.32);
    transform: scale(1.05);
  }
  .csd-lightbox-close:focus-visible {
    outline: 2px solid var(--cyan);
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .csd-lightbox-close { transition: none; }
  }
</style>
