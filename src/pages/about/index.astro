---
import Base from '../../layouts/Base.astro';
import PortableText from '../../components/PortableText.astro';
import PillarsSection from '../../components/home/PillarsSection.astro';
import { sanity } from '../../lib/sanity';
import { ABOUT_QUERY } from '../../lib/queries';

let s: any = null;
try { s = await sanity.fetch(ABOUT_QUERY); } catch { s = null; }

const HARDCODED_STATS: Array<{ value: string; label: string; note?: string }> = [
  { value: '8+',    label: 'Brands Built' },
  { value: '2.5yr', label: 'Avg Time Working Together', note: 'longest: 4 years' },
  { value: '$5M+',  label: 'Revenue Growth Contributor' },
  { value: '10x',   label: 'Content Output for Rob Dial' },
];

const PILLARS = [
  { key: 'mind',   title: 'Mind',   body: 'Strategic clarity, decision frameworks, mental performance, and clearing psychological blockers that stop growth.' },
  { key: 'body',   title: 'Body',   body: 'The operational systems required for the body to be nurtured through access to nutrition and regular fitness habits.' },
  { key: 'soul',   title: 'Soul',   body: 'Legacy building, IP development, thought leadership positioning, and turning your expertise into community building.' },
  { key: 'pocket', title: 'Pocket', body: 'Revenue systems, opportunity sourcing, deal structuring, and building the financial engine that funds your vision.' },
];

const heroHeadline = s?.heroHeadline ?? 'My Why.';
const stats = s?.stats && s.stats.length ? s.stats : HARDCODED_STATS;

const pageTitle = s?.seo?.title ?? 'About Kris San — CWK. Experience';
const pageDescription = s?.seo?.description ?? 'Kris San is the founder of CWK. Experience — the sports agent for entrepreneurs. Long-term business management, not consulting.';
---

<Base
  title={pageTitle}
  description={pageDescription}
>
  <!-- ── Hero ─────────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-inner">
      <span class="eyebrow fade-up">About Kris</span>
      <h1 class="hero-headline fade-up fade-up-delay-1">{heroHeadline}</h1>
      {!s?.bio && (
        <>
          <blockquote class="hero-quote fade-up fade-up-delay-2">
            <p>I didn't grow up around entrepreneurship, wealth, or legacy.</p>
            <p>I grew up watching what it looks like to never live up to your potential, and I made a vow to never let that be my story.</p>
            <p>I exist to help exceptional people turn their creative power into a brand that sets them free.</p>
          </blockquote>
          <div class="hero-ctas fade-up fade-up-delay-3">
            <a href="/about/journey" class="btn btn-primary">Learn More About My Journey →</a>
            <a href="/work" class="btn btn-secondary">See The Work →</a>
          </div>
        </>
      )}
    </div>
  </section>

  {s?.bio && (
    <!-- ── Bio Card (Sanity-driven path only) ──────────────── -->
    <section class="section bio-section">
      <div class="section-inner">
        <div class="bio-card glass-card">
          <div class="bio-body pt-body"><PortableText value={s.bio} /></div>
          <div class="bio-ctas">
            <a href="/about/journey" class="btn btn-primary">Learn More About My Journey →</a>
            <a href="/work" class="btn btn-secondary">See The Work →</a>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ── Stats Row ─────────────────────────────────────────── -->
  <section class="section stats-section">
    <div class="section-inner">
      <div class="stats-bar glass-card">
        {stats.map((stat: { value: string; label: string; note?: string }) => (
          <div class="stat">
            <span class="stat-number gradient-text">{stat.value}</span>
            <span class="stat-label">{stat.label}</span>
            {stat.note && <span class="stat-note">{stat.note}</span>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Four Pillars (PLOS Framework) ─────────────────────── -->
  <PillarsSection pillars={PILLARS} />

  <!-- ── Closing CTA ───────────────────────────────────────── -->
  <section class="section about-cta-section">
    <div class="section-inner">
      <div class="about-cta-inner">
        <a href="/#waitlist" class="btn btn-primary">Join the Waitlist →</a>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ── Hero ─────────────────────────────────────────── */
  .hero {
    padding-top: 144px;
    padding-bottom: 80px;
    padding-left: 24px;
    padding-right: 24px;
    text-align: center;
  }

  .hero-inner {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .hero-inner .eyebrow {
    margin-bottom: 20px;
  }

  .hero-headline {
    font-size: clamp(48px, 8vw, 80px);
    font-weight: 800;
    line-height: 1.0;
    letter-spacing: -0.04em;
    color: var(--text);
    margin-bottom: 40px;
  }

  .hero-quote {
    margin: 0;
    padding: 0;
    border: none;
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 560px;
  }

  .hero-quote p {
    font-size: clamp(17px, 2.2vw, 22px);
    color: var(--muted);
    line-height: 1.6;
    font-style: italic;
  }

  .hero-quote p:first-child {
    color: var(--text);
    font-size: clamp(19px, 2.5vw, 25px);
    font-style: normal;
    font-weight: 600;
  }

  .hero-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 40px;
  }

  /* ── Bio Card ─────────────────────────────────────── */
  .bio-card {
    padding: var(--pad-lg);
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: 800px;
    margin: 0 auto;
  }

  .bio-card .eyebrow {
    margin-bottom: 4px;
  }

  .bio-body {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .bio-body p {
    font-size: 16px;
    color: var(--muted);
    line-height: 1.7;
  }

  /* Portable Text rendering (mirrors .bio-body but flat children). */
  .bio-body.pt-body :global(p) {
    font-size: 16px;
    color: var(--muted);
    line-height: 1.7;
    margin: 0 0 16px;
  }
  .bio-body.pt-body :global(p:last-child) { margin-bottom: 0; }
  .bio-body.pt-body :global(h2) {
    font-size: 20px;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.01em;
    margin: 16px 0 12px;
  }
  .bio-body.pt-body :global(h2:first-child) { margin-top: 0; }
  .bio-body.pt-body :global(ul) {
    list-style: none;
    padding-left: 0;
    margin: 0 0 12px;
  }
  .bio-body.pt-body :global(li) {
    font-size: 15px;
    color: var(--muted);
    line-height: 1.65;
    padding-left: 20px;
    position: relative;
    margin-bottom: 8px;
  }
  .bio-body.pt-body :global(li::before) {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--cyan);
    font-size: 11px;
    top: 3px;
  }
  .bio-body.pt-body :global(strong) { color: var(--text); font-weight: 600; }
  .bio-body.pt-body :global(a)      { color: var(--cyan); }

  .bio-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 8px;
  }

  /* ── Stats (2×2 grid with internal dividers) ───────── */
  .stats-bar {
    display: grid;
    grid-template-columns: 1fr 1fr;
    padding: 0;
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
    overflow: hidden;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: center;
    justify-content: center;
    padding: 36px 24px;
  }

  /* Internal "+" divider: bottom border on top row, right border on left col */
  .stat:nth-child(-n+2) { border-bottom: 1px solid var(--gb); }
  .stat:nth-child(odd)  { border-right: 1px solid var(--gb); }

  .stat-number {
    font-size: clamp(28px, 4vw, 38px);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .stat-label {
    font-size: 11px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 1.4;
    max-width: 22ch;
  }

  .stat-note {
    font-size: 11px;
    color: var(--dim);
    font-style: italic;
    letter-spacing: 0.02em;
  }

  /* ── Closing CTA ──────────────────────────────────── */
  .about-cta-section {
    padding-top: 40px;
    padding-bottom: 16px;
  }
  .about-cta-inner {
    display: flex;
    justify-content: center;
  }

  /* ── Responsive ───────────────────────────────────── */
  @media (max-width: 640px) {
    .hero {
      padding-top: 112px;
      padding-bottom: 60px;
    }

    .bio-card {
      padding: var(--pad-md);
    }

    .bio-ctas,
    .hero-ctas {
      flex-direction: column;
      width: 100%;
    }

    .stats-bar {
      grid-template-columns: 1fr;
    }
    /* Single-column: horizontal divider between every stat */
    .stat:nth-child(-n+2)  { border-bottom: 1px solid var(--gb); }
    .stat:nth-child(3)     { border-bottom: 1px solid var(--gb); }
    .stat:nth-child(odd)   { border-right: none; }
    .stat { padding: 24px 20px; }
  }
</style>
