---
import Base from '../../layouts/Base.astro';
import PortableText from '../../components/PortableText.astro';
import { sanity } from '../../lib/sanity';
import { ABOUT_QUERY } from '../../lib/queries';

let s: any = null;
try { s = await sanity.fetch(ABOUT_QUERY); } catch { s = null; }

const heroHeadline = s?.heroHeadline ?? 'My Why.';

const pageTitle = s?.seo?.title ?? 'About Kris San | CWK. Experience';
const pageDescription = s?.seo?.description ?? 'Kris San is the founder of CWK. Experience, the sports agent for entrepreneurs. Long-term business management, not consulting.';
---

<Base
  title={pageTitle}
  description={pageDescription}
>
  <!-- ── Hero ─────────────────────────────────────────────── -->
  <section class="hero">
    <video
      class="hero-video"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster="/videos/about-kris/poster.jpg"
      aria-hidden="true"
    >
      <source src="/videos/about-kris/loop.webm" type="video/webm" />
      <source src="/videos/about-kris/loop.mp4" type="video/mp4" />
    </video>
    <div class="hero-overlay" aria-hidden="true"></div>

    <div class="hero-inner">
      <span class="eyebrow fade-up">About Kris</span>
      <h1 class="hero-headline fade-up fade-up-delay-1">{heroHeadline}</h1>
      {!s?.bio && (
        <>
          <blockquote class="hero-quote fade-up fade-up-delay-2">
            <p>I didn't grow up around entrepreneurship, wealth, or legacy.</p>
            <p>I grew up watching what it looks like to never live up to your potential, and I made a vow to never let that be my story.</p>
            <p>I exist to help exceptional people turn their creative power into a brand that sets them free.</p>
          </blockquote>
          <div class="hero-ctas fade-up fade-up-delay-3">
            <a href="/about/journey" class="btn btn-primary">Learn More About My Journey →</a>
            <a href="/case-studies" class="btn btn-secondary">See The Case Studies →</a>
            <a href="/side-quests" class="btn btn-secondary">See Side Quests →</a>
          </div>
          <img
            class="hero-signature fade-up fade-up-delay-4"
            src="/images/about-kris/kris-signature.webp"
            alt="Kris San signature"
            width="320"
            height="320"
            loading="lazy"
            decoding="async"
          />
        </>
      )}
    </div>
  </section>

  {s?.bio && (
    <!-- ── Bio Card (Sanity-driven path only) ──────────────── -->
    <section class="section bio-section">
      <div class="section-inner">
        <div class="bio-card glass-card">
          <div class="bio-body pt-body"><PortableText value={s.bio} /></div>
          <div class="bio-ctas">
            <a href="/about/journey" class="btn btn-primary">Learn More About My Journey →</a>
            <a href="/case-studies" class="btn btn-secondary">See The Case Studies →</a>
            <a href="/side-quests" class="btn btn-secondary">See Side Quests →</a>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ── Closing CTA ───────────────────────────────────────── -->
  <section class="section about-cta-section">
    <div class="section-inner">
      <div class="about-cta-inner">
        <a href="/#waitlist" class="btn btn-primary">Join the Waitlist →</a>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ── Hero with background video ────────────────────── */
  .hero {
    position: relative;
    overflow: hidden;
    padding-top: 144px;
    padding-bottom: 80px;
    padding-left: 24px;
    padding-right: 24px;
    text-align: center;
    isolation: isolate;
  }

  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: -2;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at center, rgba(7, 9, 15, 0.55) 0%, rgba(7, 9, 15, 0.85) 70%, rgba(7, 9, 15, 0.95) 100%),
      linear-gradient(180deg, rgba(7, 9, 15, 0.4) 0%, rgba(7, 9, 15, 0.7) 100%);
    z-index: -1;
  }

  .hero-inner {
    position: relative;
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .hero-inner .eyebrow {
    margin-bottom: 20px;
  }

  .hero-headline {
    font-size: clamp(48px, 8vw, 80px);
    font-weight: 800;
    line-height: 1.0;
    letter-spacing: -0.04em;
    color: var(--text);
    margin-bottom: 40px;
  }

  .hero-quote {
    margin: 0;
    padding: 0;
    border: none;
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 560px;
  }

  .hero-quote p {
    font-size: clamp(17px, 2.2vw, 22px);
    color: var(--muted);
    line-height: 1.6;
    font-style: italic;
  }

  .hero-quote p:first-child {
    color: var(--text);
    font-size: clamp(19px, 2.5vw, 25px);
    font-style: normal;
    font-weight: 600;
  }

  .hero-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 40px;
  }

  .hero-signature {
    margin-top: 40px;
    width: clamp(180px, 22vw, 260px);
    height: auto;
    opacity: 0.92;
    filter: drop-shadow(0 4px 16px rgba(0, 0, 0, 0.5));
  }

  /* ── Bio Card ─────────────────────────────────────── */
  .bio-card {
    padding: var(--pad-lg);
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: 800px;
    margin: 0 auto;
  }

  .bio-card .eyebrow {
    margin-bottom: 4px;
  }

  .bio-body {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .bio-body p {
    font-size: 16px;
    color: var(--muted);
    line-height: 1.7;
  }

  /* Portable Text rendering (mirrors .bio-body but flat children). */
  .bio-body.pt-body :global(p) {
    font-size: 16px;
    color: var(--muted);
    line-height: 1.7;
    margin: 0 0 16px;
  }
  .bio-body.pt-body :global(p:last-child) { margin-bottom: 0; }
  .bio-body.pt-body :global(h2) {
    font-size: 20px;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.01em;
    margin: 16px 0 12px;
  }
  .bio-body.pt-body :global(h2:first-child) { margin-top: 0; }
  .bio-body.pt-body :global(ul) {
    list-style: none;
    padding-left: 0;
    margin: 0 0 12px;
  }
  .bio-body.pt-body :global(li) {
    font-size: 15px;
    color: var(--muted);
    line-height: 1.65;
    padding-left: 20px;
    position: relative;
    margin-bottom: 8px;
  }
  .bio-body.pt-body :global(li::before) {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--cyan);
    font-size: 11px;
    top: 3px;
  }
  .bio-body.pt-body :global(strong) { color: var(--text); font-weight: 600; }
  .bio-body.pt-body :global(a)      { color: var(--cyan); }

  .bio-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 8px;
  }

  /* ── Closing CTA ──────────────────────────────────── */
  .about-cta-section {
    padding-top: 40px;
    padding-bottom: 16px;
  }
  .about-cta-inner {
    display: flex;
    justify-content: center;
  }

  /* ── Responsive ───────────────────────────────────── */
  @media (max-width: 640px) {
    .hero {
      padding-top: 112px;
      padding-bottom: 60px;
    }

    .bio-card {
      padding: var(--pad-md);
    }

    .bio-ctas,
    .hero-ctas {
      flex-direction: column;
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-video {
      display: none;
    }
    .hero-overlay {
      background: rgba(7, 9, 15, 0.95);
    }
  }
</style>
