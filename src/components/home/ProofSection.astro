---
const stats = [
  { number: '$1M <span class="stat-arrow" aria-hidden="true">→</span> $5M', label: 'Revenue Growth' },
  { number: '10x', label: 'Content Output' },
  { number: '20–30%', label: 'Shorter Sales Cycles' },
  { number: '60%', label: 'Less Decision Fatigue' },
  { number: '80%', label: 'Less Messaging Confusion' },
  { number: '6-Figure', label: 'Grants Secured' },
];
---

<section class="section proof">
  <div class="section-inner">
    <div class="proof-grid">
      {stats.map((s, i) => (
        <div class="stat-card reveal-card" style={`--reveal-i:${i}`}>
          <span class="stat-number" set:html={s.number} />
          <span class="stat-label">{s.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .proof-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  /* 6-up row only when there's genuinely room for each card's content */
  @media (min-width: 1200px) {
    .proof-grid {
      grid-template-columns: repeat(6, minmax(0, 1fr));
      gap: 16px;
    }
  }

  .stat-card {
    position: relative;
    overflow: hidden;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 28px 16px;
    border: 1px solid var(--gb);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.02);
    text-align: center;
    transition:
      transform 0.5s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.3s ease,
      box-shadow 0.5s cubic-bezier(0.22, 1, 0.36, 1),
      background 0.4s ease;
  }

  .stat-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(0, 229, 255, 0.10) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }

  /* Top hairline accent that grows in on hover */
  .stat-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    width: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, #00E5FF, transparent);
    transform: translateX(-50%);
    transition: width 0.6s cubic-bezier(0.22, 1, 0.36, 1);
    pointer-events: none;
  }

  .stat-card > * { position: relative; z-index: 1; }

  .stat-number {
    font-size: clamp(20px, 1.9vw, 26px);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1;
    color: #00E5FF;
    white-space: nowrap;
    display: inline-flex;
    align-items: baseline;
    gap: 0.15em;
    max-width: 100%;
  }

  .stat-arrow {
    display: inline-block;
    color: #00E5FF;
    opacity: 0.7;
    transform: translateY(-0.04em);
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.3s ease;
  }

  .stat-label {
    font-size: 12px;
    font-weight: 600;
    color: var(--muted);
    text-transform: none;
    letter-spacing: 0.02em;
    line-height: 1.35;
    max-width: 14ch;
  }

  @media (hover: hover) {
    .stat-card:hover {
      transform: translateY(-3px);
      border-color: rgba(0, 229, 255, 0.28);
      box-shadow: 0 10px 32px rgba(0, 0, 0, 0.32);
      background: rgba(0, 229, 255, 0.025);
    }
    .stat-card:hover::before { opacity: 1; }
    .stat-card:hover::after { width: 70%; }
    .stat-card:hover .stat-arrow {
      transform: translate(4px, -0.04em);
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .stat-card, .stat-card::after, .stat-arrow { transition: none !important; }
    .stat-card:hover { transform: none !important; }
  }

  @media (max-width: 768px) {
    .stat-card { padding: 22px 12px; gap: 8px; }
    .stat-label { font-size: 11px; }
  }

  @media (max-width: 640px) {
    .proof-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 10px; }
    .stat-card { padding: 20px 10px; }
    .stat-number { font-size: 20px; }
    .stat-label { font-size: 11px; max-width: 16ch; }
  }
</style>
