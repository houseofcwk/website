---
import WaitlistForm from '../WaitlistForm';
---

<section id="waitlist" class="section waitlist-section">
  <div class="wl-inner">
    <div class="wl-card">
      <!-- Left: copy + form -->
      <div class="wl-content reveal-up">
        <span class="wl-eyebrow">
          <span class="wl-eyebrow-dot"></span>
          COMING SOON
        </span>
        <h2 class="wl-heading"><span class="wl-heading-grad">Command Center</span></h2>
        <p class="wl-tagline">Your Personal Operating System for Growth.</p>

        <div class="wl-body">
          <p class="wl-body-lede">Three layers. One experience.</p>
          <ul class="wl-layers">
            <li>
              <span class="wl-layer-name wl-layer-name--plos">PLOS</span>
              <span class="wl-layer-text">, the data infrastructure that tracks everything.</span>
            </li>
            <li>
              <span class="wl-layer-name wl-layer-name--kaia">Kaia</span>
              <span class="wl-layer-text">, the AI agent that holds it all so you don't have to.</span>
            </li>
            <li>
              <span class="wl-layer-name wl-layer-name--pod">Human Pod</span>
              <span class="wl-layer-text">, the people who stay in it with you.</span>
            </li>
          </ul>
          <p class="wl-body-coda">Built for the Operator ready to become Sovereign.</p>
        </div>

        <WaitlistForm client:visible />
      </div>

      <!-- Right: mini dashboard mockup -->
      <div class="wl-visual reveal-card" style="--reveal-i:1">
        <span class="wl-visual-glow" aria-hidden="true"></span>
        <div class="wl-mock">
          <img
            src="/images/home/agent-minidash.webp"
            alt="Agent+ preview showing task cards and KAIA AI prompt."
            class="wl-mock-img"
            width="960"
            height="940"
            loading="lazy"
            decoding="async"
          />
          <span class="wl-mock-shimmer" aria-hidden="true"></span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .waitlist-section {
    padding-top: 96px;
    padding-bottom: 96px;
    background: var(--bg);
  }

  .wl-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .wl-card {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 480px;
    background: var(--glass);
    border: 1px solid var(--gb);
    border-radius: 16px;
    overflow: hidden;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }

  /* Left */
  .wl-content {
    padding: 56px 48px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    align-items: flex-start;
  }

  .wl-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    background: rgba(123, 97, 255, 0.08);
    border: 1px solid rgba(123, 97, 255, 0.22);
    border-radius: 100px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--purple);
  }
  .wl-eyebrow-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--purple);
    box-shadow: 0 0 8px rgba(123, 97, 255, 0.55);
    animation: wl-dot-pulse 2.6s ease-in-out infinite;
  }
  @keyframes wl-dot-pulse {
    0%, 100% { transform: scale(1);   box-shadow: 0 0 8px  rgba(123, 97, 255, 0.55); }
    50%       { transform: scale(1.25); box-shadow: 0 0 14px rgba(123, 97, 255, 0.85); }
  }

  .wl-heading {
    font-size: clamp(36px, 5vw, 52px);
    font-weight: 800;
    line-height: 1.02;
    letter-spacing: -0.03em;
    margin: 0;
  }
  .wl-heading-grad {
    background: linear-gradient(135deg, #FFFFFF 0%, #C9C2FF 60%, #7B61FF 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .wl-tagline {
    font-size: clamp(17px, 1.9vw, 20px);
    font-weight: 600;
    color: var(--text);
    line-height: 1.4;
    margin: 0;
    letter-spacing: -0.005em;
  }

  /* ── Body: layered explainer ─────────────────────────── */
  .wl-body {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 18px 20px;
    background: rgba(123, 97, 255, 0.04);
    border: 1px solid rgba(123, 97, 255, 0.18);
    border-radius: 12px;
    width: 100%;
  }
  .wl-body-lede {
    margin: 0;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--purple);
  }
  .wl-layers {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .wl-layers li {
    position: relative;
    padding-left: 22px;
    font-size: 14.5px;
    line-height: 1.55;
    color: var(--muted);
  }
  .wl-layers li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.65em;
    width: 12px;
    height: 1px;
    background: rgba(255, 255, 255, 0.25);
  }
  .wl-layer-name {
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.005em;
  }
  .wl-layer-name--plos { color: #00E5FF; }
  .wl-layer-name--kaia { color: #7B61FF; }
  .wl-layer-name--pod  { color: #FB3079; }
  .wl-layer-text { color: var(--muted); }

  .wl-body-coda {
    margin: 4px 0 0;
    padding-top: 14px;
    border-top: 1px dashed rgba(255, 255, 255, 0.08);
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
    line-height: 1.45;
    letter-spacing: -0.005em;
  }

  /* Right visual */
  .wl-visual {
    position: relative;
    padding: 48px 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(180deg, rgba(123, 97, 255, 0.05), rgba(0, 229, 255, 0.025) 60%, transparent);
    border-left: 1px solid var(--gb);
    overflow: hidden;
  }

  .wl-visual-glow {
    position: absolute;
    top: 20%;
    left: 30%;
    width: 320px;
    height: 260px;
    background: radial-gradient(ellipse, rgba(123, 97, 255, 0.08) 0%, transparent 70%);
    filter: blur(12px);
    pointer-events: none;
    animation: wl-float 10s ease-in-out infinite;
  }
  @keyframes wl-float {
    0%, 100% { transform: translate(0, 0); }
    50%       { transform: translate(20px, -15px); }
  }

  .wl-mock {
    position: relative;
    width: 100%;
    max-width: 400px;
    border-radius: 12px;
    overflow: hidden;
    background: var(--bg);
    border: 1px solid var(--gb);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4);
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.6s ease;
    animation: wl-mock-float 8s ease-in-out infinite;
  }
  @keyframes wl-mock-float {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-6px); }
  }
  .wl-mock-img {
    display: block;
    width: 100%;
    height: auto;
  }

  .wl-mock-shimmer {
    position: absolute;
    top: 0;
    left: -40%;
    width: 30%;
    height: 100%;
    background: linear-gradient(
      100deg,
      transparent 20%,
      rgba(123, 97, 255, 0.14) 50%,
      transparent 80%
    );
    pointer-events: none;
    transform: skewX(-12deg);
    opacity: 0;
  }
  .wl-visual.is-visible .wl-mock-shimmer {
    animation: wl-shimmer 1.8s 0.4s ease-out forwards;
  }
  @keyframes wl-shimmer {
    0%   { opacity: 0; left: -40%; }
    30%  { opacity: 1; }
    100% { opacity: 0; left: 130%; }
  }

  @media (hover: hover) {
    .wl-mock:hover {
      transform: translateY(-4px) scale(1.01);
      box-shadow: 0 28px 64px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(123, 97, 255, 0.18);
    }
  }

  /* Waitlist form width fit */
  .wl-content :global(.waitlist-wrap) {
    margin: 0;
    max-width: 100%;
    width: 100%;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .wl-card { grid-template-columns: 1fr; }
    .wl-visual { border-left: none; border-top: 1px solid var(--gb); padding: 40px 24px; }
    .wl-content { padding: 44px 28px; }
    .waitlist-section { padding-top: 64px; padding-bottom: 64px; }
  }
  @media (max-width: 480px) {
    .wl-content { padding: 36px 22px; gap: 18px; }
    .wl-visual { padding: 32px 20px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .wl-eyebrow-dot, .wl-visual-glow, .wl-mock { animation: none !important; }
    .wl-mock-shimmer { display: none; }
  }
</style>
