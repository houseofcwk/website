---
import { CASE_STUDIES } from '../../data/caseStudies';

// Curate the home-page portfolio: pull canonical case studies, prefer those
// with a cardImage, sort by editorial order, then take the first 6.
const portfolio = CASE_STUDIES
  .filter((c) => Boolean(c.cardImage))
  .sort((a, b) => a.order - b.order)
  .slice(0, 6);
---

<section class="section portfolio-section" aria-labelledby="portfolio-heading">
  <div class="section-inner">
    <header class="portfolio-header">
      <span class="pill-eyebrow reveal-up">
        <span class="pill-dot" aria-hidden="true"></span>
        The Portfolio
      </span>
      <h2 id="portfolio-heading" class="portfolio-title reveal-up reveal-delay-1">Real brands. Measurable results.</h2>
      <p class="portfolio-sub reveal-up reveal-delay-2">
        From podcasters to non-profits to creative founders, CWK. builds the infrastructure that brings your vision to life.
      </p>
    </header>

    <ul class="portfolio-grid">
      {portfolio.map((c, i) => (
        <li class="portfolio-card-item" style={`--reveal-i:${i}`}>
          <a
            href={`/case-studies/${c.slug}`}
            class={`portfolio-card reveal-card`}
            style={`--accent: ${c.cardAccent}`}
            aria-label={`${c.client} — ${c.cardDescription}`}
          >
            <div class="portfolio-card-img">
              <img
                src={c.cardImage}
                alt={c.cardImageAlt ?? c.client}
                width="900"
                height="600"
                loading="lazy"
                decoding="async"
              />
              <span class="portfolio-card-stat" aria-hidden="true">
                <span class="portfolio-card-stat-num">{c.cardStat.num}</span>
                <span class="portfolio-card-stat-label">{c.cardStat.label}</span>
              </span>
            </div>
            <div class="portfolio-card-body">
              <span class="portfolio-card-cat">{c.category}</span>
              <h3 class="portfolio-card-title">{c.client}</h3>
              <p class="portfolio-card-desc">{c.cardDescription}</p>
              <span class="portfolio-card-cta">
                Read the case study
                <svg class="portfolio-card-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                </svg>
              </span>
            </div>
          </a>
        </li>
      ))}
    </ul>

    <div class="portfolio-cta reveal-up reveal-delay-3">
      <a href="/case-studies" class="btn btn-ghost">See All Case Studies →</a>
    </div>
  </div>
</section>

<style>
  .portfolio-section {
    position: relative;
    padding-top: 96px;
    padding-bottom: 96px;
  }

  /* ── Header ───────────────────────────────────────────── */
  .portfolio-header {
    text-align: left;
    margin-bottom: 44px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .portfolio-title {
    font-size: clamp(28px, 4.6vw, 44px);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--text);
    margin: 0;
  }
  .portfolio-sub {
    font-size: clamp(14px, 1.4vw, 16px);
    color: var(--muted);
    margin: 0;
    max-width: 560px;
    line-height: 1.55;
  }

  /* ── Grid ────────────────────────────────────────────── */
  .portfolio-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
  }
  .portfolio-card-item { display: flex; }

  /* ── Card ────────────────────────────────────────────── */
  .portfolio-card {
    --accent: #00E5FF;
    position: relative;
    display: flex;
    flex-direction: column;
    width: 100%;
    background: var(--glass);
    border: 1px solid var(--gb);
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    isolation: isolate;
    transition:
      transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.35s ease,
      box-shadow 0.4s ease;
  }

  /* Image area */
  .portfolio-card-img {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: rgba(0, 0, 0, 0.4);
  }
  .portfolio-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1), filter 0.4s ease;
    filter: saturate(0.96);
  }
  .portfolio-card-img::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(7, 9, 15, 0) 35%,
      rgba(7, 9, 15, 0.55) 100%
    );
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  /* Stat badge floating bottom-left of image */
  .portfolio-card-stat {
    position: absolute;
    left: 14px;
    bottom: 14px;
    z-index: 2;
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1px;
    padding: 8px 12px;
    border-radius: 10px;
    background: rgba(7, 9, 15, 0.62);
    border: 1px solid rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: border-color 0.3s ease, background 0.3s ease;
  }
  .portfolio-card-stat-num {
    font-size: 17px;
    font-weight: 800;
    letter-spacing: -0.01em;
    color: var(--accent);
    line-height: 1.05;
  }
  .portfolio-card-stat-label {
    font-size: 9.5px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.78);
  }

  /* Body */
  .portfolio-card-body {
    flex-grow: 1;
    padding: 22px 22px 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .portfolio-card-cat {
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    opacity: 0.9;
  }
  .portfolio-card-title {
    margin: 0;
    font-size: clamp(20px, 2vw, 24px);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--text);
    line-height: 1.18;
  }
  .portfolio-card-desc {
    margin: 0;
    font-size: 14px;
    line-height: 1.55;
    color: var(--muted);
    flex-grow: 1;
  }
  .portfolio-card-cta {
    margin-top: 6px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.005em;
    color: var(--text);
  }
  .portfolio-card-arrow {
    transition: transform 0.3s ease;
    flex-shrink: 0;
  }

  /* Accent hairline along the top of each card, themed per study */
  .portfolio-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    opacity: 0;
    transition: opacity 0.4s ease;
    z-index: 3;
  }

  @media (hover: hover) {
    .portfolio-card:hover {
      transform: translateY(-6px);
      border-color: color-mix(in srgb, var(--accent) 45%, var(--gb));
      box-shadow:
        0 22px 60px rgba(0, 0, 0, 0.45),
        0 0 0 1px color-mix(in srgb, var(--accent) 25%, transparent);
    }
    .portfolio-card:hover::before { opacity: 1; }
    .portfolio-card:hover .portfolio-card-img img {
      transform: scale(1.06);
      filter: saturate(1.05);
    }
    .portfolio-card:hover .portfolio-card-cta { color: var(--accent); }
    .portfolio-card:hover .portfolio-card-arrow { transform: translateX(4px); }
    .portfolio-card:hover .portfolio-card-stat {
      border-color: color-mix(in srgb, var(--accent) 50%, transparent);
      background: rgba(7, 9, 15, 0.78);
    }
  }

  .portfolio-card:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .portfolio-cta {
    text-align: center;
    margin-top: 44px;
  }

  /* ── Responsive ──────────────────────────────────────── */
  @media (max-width: 960px) {
    .portfolio-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 18px; }
  }
  @media (max-width: 640px) {
    .portfolio-section { padding-top: 64px; padding-bottom: 64px; }
    .portfolio-grid { grid-template-columns: 1fr; gap: 16px; }
    .portfolio-card-body { padding: 18px 18px 20px; }
    .portfolio-header { margin-bottom: 28px; }
    .portfolio-cta { margin-top: 28px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .portfolio-card,
    .portfolio-card-img img,
    .portfolio-card-arrow,
    .portfolio-card::before {
      transition: none !important;
    }
  }
</style>
