---
interface WorkItem {
  href: string;
  img: string;
  alt: string;
  width: number;
  height: number;
  tag: string;
  title: string;
  meta: string;
  wide?: boolean;
}

const items: WorkItem[] = [
  { href: '/work/the-lab-miami', img: '/images/work/lab-miami.webp', alt: 'The LAB Miami innovation campus', width: 1440, height: 804, tag: 'Builder Hub', title: 'The LAB Miami', meta: '20–30% faster sales cycles', wide: true },
  { href: '/work/rob-dial',      img: '/images/work/rob-dial.webp',  alt: 'Rob Dial podcast studio',       width: 1200, height: 654, tag: 'Podcast',       title: 'Rob Dial',      meta: 'Revenue $1M → $5M' },
  { href: '/work/spraycation',   img: '/images/work/spraycation.webp', alt: 'SPRAYCATION experiential art tour', width: 1000, height: 546, tag: 'Experiential', title: 'SPRAYCATION',   meta: '6-city tour executed' },
  { href: '/work/dawa',          img: '/images/work/dawa.webp',       alt: 'DAWA non-profit education program', width: 1000, height: 546, tag: 'Non-Profit',   title: 'DAWA',          meta: 'A dignity project unveiled' },
  { href: '/work/stephy-lee',    img: '/images/work/stephy-lee.webp', alt: 'Stephy Lee music artist',       width: 1000, height: 546, tag: 'Creative Founder', title: 'Stephy Lee', meta: 'SXSW stage secured' },
];
---

<section class="section work-mosaic">
  <div class="section-inner">
    <div class="work-mosaic-header">
      <span class="pill-eyebrow reveal-up">
        <span class="pill-dot" aria-hidden="true"></span>
        The Work
      </span>
      <h2 class="work-mosaic-title reveal-up reveal-delay-1">Real brands. Measurable results.</h2>
      <p class="work-mosaic-sub reveal-up reveal-delay-2">From podcasters to non-profits to creative founders — CWK. builds the infrastructure that brings your vision to life.</p>
    </div>

    <div class="mosaic-grid">
      {items.map((it, i) => (
        <a href={it.href} class={`mosaic-card ${it.wide ? 'mosaic-card--wide' : ''} reveal-card`} style={`--reveal-i:${i}`}>
          <img src={it.img} alt={it.alt} width={it.width} height={it.height} loading="lazy" decoding="async" />
          <div class="mosaic-overlay">
            <span class="mosaic-tag">{it.tag}</span>
            <h3 class="mosaic-title">{it.title}</h3>
            <p class="mosaic-meta">{it.meta}</p>
            <span class="mosaic-arrow" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </div>
        </a>
      ))}
    </div>

    <div class="work-cta reveal-up reveal-delay-3">
      <a href="/work" class="btn btn-ghost">See All Work →</a>
    </div>
  </div>
</section>

<style>
  .work-mosaic-header {
    text-align: left;
    margin-bottom: 32px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .work-mosaic-title {
    font-size: clamp(28px, 4.6vw, 44px);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--text);
    margin: 0;
  }

  .work-mosaic-sub {
    font-size: clamp(14px, 1.4vw, 16px);
    color: var(--muted);
    margin: 0;
    max-width: 560px;
    line-height: 1.55;
  }

  .mosaic-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-template-rows: minmax(0, 380px) minmax(0, 280px);
    grid-template-areas:
      "a a a a b b"
      "c c d d e e";
    gap: 8px;
  }
  .mosaic-card:nth-child(1) { grid-area: a; }
  .mosaic-card:nth-child(2) { grid-area: b; }
  .mosaic-card:nth-child(3) { grid-area: c; }
  .mosaic-card:nth-child(4) { grid-area: d; }
  .mosaic-card:nth-child(5) { grid-area: e; }

  .mosaic-card {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-card, 14px);
    border: 1px solid var(--gb);
    text-decoration: none;
    color: inherit;
    background: rgba(255, 255, 255, 0.02);
    isolation: isolate;
    transform: translateZ(0);
    transition:
      transform 0.5s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.5s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.4s ease;
  }
  .mosaic-card img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    transition: transform 0.9s cubic-bezier(0.22, 1, 0.36, 1), filter 0.5s ease;
    filter: saturate(0.96);
  }
  .mosaic-card::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      180deg,
      rgba(7, 9, 15, 0) 0%,
      rgba(7, 9, 15, 0) 30%,
      rgba(7, 9, 15, 0.85) 100%
    );
    transition: opacity 0.4s ease;
    pointer-events: none;
  }
  .mosaic-card::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 2;
    background: radial-gradient(
      ellipse at 50% 100%,
      rgba(0, 229, 255, 0.18) 0%,
      transparent 65%
    );
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }

  .mosaic-overlay {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    height: 100%;
    padding: 28px;
    gap: 6px;
  }

  .mosaic-card:not(.mosaic-card--wide) .mosaic-overlay {
    padding: 22px;
  }

  .mosaic-tag {
    display: inline-block;
    align-self: flex-start;
    padding: 4px 10px;
    border-radius: 100px;
    background: rgba(255, 255, 255, 0.10);
    border: 1px solid rgba(255, 255, 255, 0.16);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #fff;
    margin-bottom: 6px;
    transform: translateY(6px);
    opacity: 0;
    transition:
      transform 0.5s cubic-bezier(0.22, 1, 0.36, 1) 0.05s,
      opacity 0.5s ease 0.05s;
  }

  .mosaic-title {
    font-size: clamp(20px, 2.4vw, 28px);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #fff;
    margin: 0;
    transform: translateY(8px);
    transition: transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .mosaic-meta {
    font-size: 13px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.72);
    margin: 0;
    opacity: 0.9;
    transform: translateY(8px);
    transition:
      transform 0.55s cubic-bezier(0.22, 1, 0.36, 1) 0.04s,
      opacity 0.4s ease 0.04s;
  }

  .mosaic-arrow {
    position: absolute;
    top: 22px;
    right: 22px;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.18);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: translate(-6px, 6px) rotate(-20deg);
    transition:
      opacity 0.4s ease,
      transform 0.5s cubic-bezier(0.22, 1, 0.36, 1),
      background 0.3s ease;
  }

  @media (hover: hover) {
    .mosaic-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 18px 48px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(0, 229, 255, 0.2);
      border-color: rgba(0, 229, 255, 0.25);
    }
    .mosaic-card:hover img {
      transform: scale(1.06);
      filter: saturate(1.08);
    }
    .mosaic-card:hover::after { opacity: 1; }
    .mosaic-card:hover .mosaic-title { transform: translateY(0); }
    .mosaic-card:hover .mosaic-meta { transform: translateY(0); opacity: 1; }
    .mosaic-card:hover .mosaic-arrow {
      opacity: 1;
      transform: translate(0, 0) rotate(0deg);
      background: rgba(0, 229, 255, 0.85);
      color: #07090F;
    }
  }
  .mosaic-card:focus-visible {
    outline: 2px solid #00E5FF;
    outline-offset: 3px;
  }

  .reveal-card.is-visible .mosaic-tag {
    opacity: 1;
    transform: translateY(0);
  }

  .work-cta {
    text-align: center;
    margin-top: 36px;
  }

  @media (prefers-reduced-motion: reduce) {
    .mosaic-card, .mosaic-card img, .mosaic-card .mosaic-title,
    .mosaic-card .mosaic-meta, .mosaic-card .mosaic-tag, .mosaic-card .mosaic-arrow {
      transition: none !important;
    }
    .mosaic-tag, .mosaic-title, .mosaic-meta { opacity: 1 !important; transform: none !important; }
    .mosaic-arrow { opacity: 1; transform: none; }
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .mosaic-grid {
      grid-template-columns: 1fr 1fr;
      grid-template-areas:
        "a a"
        "b c"
        "d e";
      grid-template-rows: 320px 240px 240px;
    }
  }

  @media (max-width: 640px) {
    .mosaic-grid {
      grid-template-columns: 1fr;
      grid-template-areas:
        "a"
        "b"
        "c"
        "d"
        "e";
      grid-template-rows: repeat(5, 220px);
      gap: 12px;
    }
    .work-mosaic-header { margin-bottom: 24px; }
    .mosaic-overlay,
    .mosaic-card:not(.mosaic-card--wide) .mosaic-overlay { padding: 18px; }
    .mosaic-arrow { top: 14px; right: 14px; width: 34px; height: 34px; }
    .mosaic-meta { opacity: 1; transform: none; }
    .mosaic-arrow { opacity: 1; transform: none; background: rgba(0, 229, 255, 0.85); color: #07090F; }
    .mosaic-title { transform: none; }
  }

  /* Touch-only fallback (no hover): always reveal text + arrow */
  @media (hover: none) {
    .mosaic-meta { opacity: 1; transform: none; }
    .mosaic-arrow { opacity: 1; transform: none; background: rgba(0, 229, 255, 0.85); color: #07090F; }
    .mosaic-title { transform: none; }
  }
</style>
