---
const currentPath = Astro.url.pathname;
const isActive = (path: string) => currentPath === path || currentPath.startsWith(path + '/');
---

<header class="site-header">
  <nav class="nav-inner">
    <!-- Logo -->
    <a href="/" class="logo" aria-label="CWK. Experience: Home">
      <img
        src="/logos/logo-wht-80.webp"
        srcset="/logos/logo-wht-40.webp 1x, /logos/logo-wht-80.webp 2x, /logos/logo-wht-120.webp 3x"
        alt="CWK."
        width="40"
        height="40"
        loading="eager"
        decoding="async"
      />
      <span class="beta-badge" aria-label="Beta">β</span>
    </a>

    <!-- Desktop nav links (no icons) -->
    <div class="nav-links">
      <a href="/case-studies" class:list={['nav-link', { active: isActive('/case-studies') }]}>Case Studies</a>
      <a href="/about"        class:list={['nav-link', { active: isActive('/about') }]}>About</a>
      <a href="/product"      class:list={['nav-link nav-link--soon', { active: isActive('/product') }]}>
        PLOS
        <span class="nav-soon-badge" aria-label="Coming soon">Soon</span>
      </a>
    </div>

    <div class="nav-actions">
      {currentPath !== '/' && (
        <button class="btn btn-ghost nav-join" data-open-waitlist aria-label="Join the waitlist">Join Waitlist</button>
      )}
    </div>

    <!-- Hamburger (mobile only) -->
    <button class="hamburger" id="hamburger" aria-label="Open menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </nav>
</header>

<!-- Mobile overlay (outside header so it can cover full viewport) -->
<div class="mobile-overlay" id="mobile-overlay" aria-hidden="true" role="dialog" aria-label="Mobile navigation">

  <!-- Overlay top bar: logo + close -->
  <div class="overlay-topbar">
    <a href="/" class="overlay-logo" aria-label="CWK. Home">
      <img
        src="/logos/logo-wht-80.webp"
        srcset="/logos/logo-wht-40.webp 1x, /logos/logo-wht-80.webp 2x, /logos/logo-wht-120.webp 3x"
        alt="CWK."
        width="36"
        height="36"
        loading="eager"
      />
    </a>
    <button class="overlay-close" id="overlay-close" aria-label="Close menu">
      <!-- X icon -->
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M15 5L5 15M5 5l10 10" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <!-- Nav items with icons -->
  <nav class="overlay-nav">
    <a href="/case-studies" class:list={['overlay-link', { active: isActive('/case-studies') }]}>
      <span class="overlay-icon" aria-hidden="true">
        <!-- Briefcase icon -->
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="2" y="7" width="18" height="13" rx="2" stroke="currentColor" stroke-width="1.5"/>
          <path d="M7 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" stroke="currentColor" stroke-width="1.5"/>
          <path d="M2 13h18" stroke="currentColor" stroke-width="1.5"/>
        </svg>
      </span>
      Case Studies
    </a>

    <a href="/about" class:list={['overlay-link', { active: isActive('/about') }]}>
      <span class="overlay-icon" aria-hidden="true">
        <!-- Person icon -->
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="11" cy="7" r="4" stroke="currentColor" stroke-width="1.5"/>
          <path d="M3 19c0-4 3.6-7 8-7s8 3 8 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </span>
      About
    </a>

    <a href="/product" class:list={['overlay-link', { active: isActive('/product') }]}>
      <span class="overlay-icon" aria-hidden="true">
        <!-- Grid / dashboard icon -->
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="2" y="2" width="8" height="8" rx="2" stroke="currentColor" stroke-width="1.5"/>
          <rect x="12" y="2" width="8" height="8" rx="2" stroke="currentColor" stroke-width="1.5"/>
          <rect x="2" y="12" width="8" height="8" rx="2" stroke="currentColor" stroke-width="1.5"/>
          <rect x="12" y="12" width="8" height="8" rx="2" stroke="currentColor" stroke-width="1.5"/>
        </svg>
      </span>
      PLOS
      <span class="overlay-soon-badge" aria-label="Coming soon">Soon</span>
    </a>

    {currentPath !== '/' && (
      <button class="overlay-link overlay-waitlist-btn" data-open-waitlist>
        <span class="overlay-icon" aria-hidden="true">
          <!-- Star / sparkle icon -->
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M11 2v3M11 17v3M2 11h3M17 11h3M4.93 4.93l2.12 2.12M14.95 14.95l2.12 2.12M4.93 17.07l2.12-2.12M14.95 7.05l2.12-2.12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <circle cx="11" cy="11" r="3" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </span>
        Join Waitlist
      </button>
    )}
  </nav>

  <!-- Sticky footer -->
  <div class="overlay-footer">
    <img
      src="/logos/logo-wht-80.webp"
      srcset="/logos/logo-wht-40.webp 1x, /logos/logo-wht-80.webp 2x"
      alt="CWK."
      width="32"
      height="32"
      loading="lazy"
    />
    <div class="overlay-footer-text">
      <span class="overlay-footer-brand">CWK. Experience</span>
      <span class="overlay-footer-tagline">Build. Learn. Earn. Play.</span>
    </div>
  </div>
</div>

<!-- Backdrop -->
<div class="overlay-backdrop" id="overlay-backdrop"></div>

<style>
  /* ── Site header bar ──────────────────────────────────────── */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 200;
    background: rgba(7, 9, 15, 0.9);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--gb);
    height: 64px;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    gap: 32px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    height: 100%;
  }

  /* Logo */
  .logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
    transition: opacity 0.2s ease;
  }
  .logo:hover { opacity: 0.75; }
  .logo img { display: block; width: 40px; height: 40px; object-fit: contain; }

  .beta-badge {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.06em;
    line-height: 1;
    color: var(--cyan);
    border: 1px solid rgba(0, 229, 255, 0.25);
    background: rgba(0, 229, 255, 0.08);
    padding: 2px 5px;
    border-radius: 4px;
    margin-left: 6px;
    user-select: none;
  }

  /* Desktop nav links */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 24px;
    flex: 1;
  }

  .nav-link {
    font-size: 14px;
    font-weight: 500;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s ease;
    padding: 4px 0;
  }
  .nav-link:hover,
  .nav-link.active { color: var(--text); }

  .nav-link--soon {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .nav-soon-badge {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.1em;
    line-height: 1;
    text-transform: uppercase;
    color: #C9C2FF;
    background: rgba(123, 97, 255, 0.14);
    border: 1px solid rgba(123, 97, 255, 0.32);
    padding: 3px 6px;
    border-radius: 4px;
  }
  .overlay-soon-badge {
    margin-left: 10px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #C9C2FF;
    background: rgba(123, 97, 255, 0.14);
    border: 1px solid rgba(123, 97, 255, 0.32);
    padding: 3px 7px;
    border-radius: 5px;
    line-height: 1;
  }

  /* Right-side action buttons */
  .nav-actions {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  .nav-join,
  .nav-cta-btn {
    padding: 8px 18px;
    font-size: 13px;
  }

  .nav-join {
    font-weight: 600;
  }

  /* Hamburger */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    margin-left: auto;
    border-radius: 6px;
    transition: background 0.15s ease;
  }
  .hamburger:hover { background: rgba(255,255,255,0.06); }

  .hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition: all 0.25s ease;
    transform-origin: center;
  }

  /* Hamburger → X animation when open */
  .hamburger.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.is-open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .hamburger.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ── Mobile overlay ───────────────────────────────────────── */
  .mobile-overlay {
    position: fixed;
    inset: 0;
    z-index: 190;
    background: #07090F;
    display: flex;
    flex-direction: column;
    pointer-events: none;
    opacity: 0;
    transform: translateX(100%);
    transition: opacity 0.28s ease, transform 0.28s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform, opacity;
  }

  .mobile-overlay.open {
    pointer-events: auto;
    opacity: 1;
    transform: translateX(0);
  }

  /* Overlay top bar */
  .overlay-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 24px;
    height: 64px;
    flex-shrink: 0;
    border-bottom: 1px solid var(--gb);
  }

  .overlay-logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    opacity: 0.9;
    transition: opacity 0.2s;
  }
  .overlay-logo:hover { opacity: 1; }
  .overlay-logo img { display: block; width: 36px; height: 36px; object-fit: contain; }

  .overlay-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 8px;
    background: rgba(255,255,255,0.06);
    border: 1px solid var(--gb);
    color: var(--muted);
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .overlay-close:hover {
    background: rgba(255,255,255,0.1);
    color: var(--text);
    border-color: var(--gb2);
  }

  /* Nav items */
  .overlay-nav {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 16px 0;
    overflow-y: auto;
  }

  .overlay-link {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 18px 24px;
    font-size: 22px;
    font-weight: 700;
    color: var(--muted);
    text-decoration: none;
    border-bottom: 1px solid var(--gb);
    transition: color 0.2s ease, background 0.2s ease, padding-left 0.2s ease;
    letter-spacing: -0.02em;
  }
  .overlay-link:last-child { border-bottom: none; }

  .overlay-link:hover {
    color: var(--text);
    background: rgba(255,255,255,0.03);
    padding-left: 30px;
  }

  .overlay-link.active {
    color: var(--text);
  }
  .overlay-link.active .overlay-icon {
    color: var(--cyan);
  }

  /* Join Waitlist — gradient CTA in mobile overlay */
  .overlay-waitlist-btn {
    background: none;
    border: none;
    border-bottom: none;
    width: 100%;
    text-align: left;
    cursor: pointer;
    margin-top: 8px;
    color: var(--cyan);
    background: linear-gradient(90deg, rgba(0,229,255,0.06), rgba(123,97,255,0.06));
    border-top: 1px solid var(--gb);
  }
  .overlay-waitlist-btn .overlay-icon {
    color: var(--cyan);
  }
  .overlay-waitlist-btn:hover {
    background: linear-gradient(90deg, rgba(0,229,255,0.1), rgba(123,97,255,0.1));
    padding-left: 30px;
  }

  .overlay-icon {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    color: var(--dim);
    transition: color 0.2s ease;
  }
  .overlay-link:hover .overlay-icon {
    color: var(--cyan);
  }

  /* Sticky footer */
  .overlay-footer {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 20px 24px;
    border-top: 1px solid var(--gb);
    background: rgba(255,255,255,0.015);
  }

  .overlay-footer img {
    display: block;
    width: 32px;
    height: 32px;
    object-fit: contain;
    opacity: 0.7;
  }

  .overlay-footer-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .overlay-footer-brand {
    font-size: 13px;
    font-weight: 700;
    color: var(--muted);
    letter-spacing: -0.01em;
  }

  .overlay-footer-tagline {
    font-size: 11px;
    color: var(--dim);
    letter-spacing: 0.03em;
  }

  /* Backdrop (tap to close) */
  .overlay-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 180;
    background: rgba(0,0,0,0.5);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
  }
  .overlay-backdrop.open { display: block; }

  /* ── Responsive ───────────────────────────────────────────── */
  @media (max-width: 768px) {
    .nav-links,
    .nav-actions { display: none; }
    .hamburger { display: flex; }
  }

  @media (min-width: 769px) {
    .mobile-overlay,
    .overlay-backdrop { display: none !important; }
  }
</style>

<script>
  const hamburger  = document.getElementById('hamburger') as HTMLButtonElement | null;
  const overlay    = document.getElementById('mobile-overlay') as HTMLElement | null;
  const backdrop   = document.getElementById('overlay-backdrop') as HTMLElement | null;
  const closeBtn   = document.getElementById('overlay-close') as HTMLButtonElement | null;

  function openMenu() {
    overlay?.classList.add('open');
    backdrop?.classList.add('open');
    hamburger?.classList.add('is-open');
    hamburger?.setAttribute('aria-expanded', 'true');
    overlay?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    overlay?.classList.remove('open');
    backdrop?.classList.remove('open');
    hamburger?.classList.remove('is-open');
    hamburger?.setAttribute('aria-expanded', 'false');
    overlay?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  hamburger?.addEventListener('click', () => {
    overlay?.classList.contains('open') ? closeMenu() : openMenu();
  });

  closeBtn?.addEventListener('click', closeMenu);
  backdrop?.addEventListener('click', closeMenu);

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });

  // Close when navigating to a new page or triggering modal
  overlay?.querySelectorAll('.overlay-link').forEach(link => {
    link.addEventListener('click', closeMenu);
  });
</script>
